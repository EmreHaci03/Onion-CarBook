@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Erişim Engellendi</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f5f5f5;
        }

        .container {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            width: 350px;
            text-align: center;
        }

        .icon {
            font-size: 48px;
            margin-bottom: 16px;
        }

        h2 {
            color: #333;
            margin-bottom: 10px;
        }

        p {
            color: #666;
            font-size: 14px;
            margin-bottom: 30px;
        }

        a {
            display: block;
            width: 100%;
            padding: 12px;
            background: #3498db;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            text-decoration: none;
            box-sizing: border-box;
        }

            a:hover {
                background: #2980b9;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="icon">🔒</div>
        <h2>Erişim Engellendi</h2>
        <p>Bu sayfayı görüntüleme yetkiniz bulunmamaktadır. Devam etmek için lütfen giriş yapın.</p>
        <a href="/Login/Index">Giriş Yap</a>
    </div>
</body>
</html>