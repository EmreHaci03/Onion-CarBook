@model List<GetRentACarListDto>
@{
    ViewData["Title"] = "Kiralık Araçlar";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
<section class="hero-wrap hero-wrap-2" style="background-image: url('/carbook-master/images/bg_2.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text align-items-end justify-content-center">
            <div class="col-md-9 ftco-animate pb-5 text-center">
                <p class="breadcrumbs">
                    <span class="mr-2"><a href="/Default/Index/">Ana Sayfa <i class="ion-ios-arrow-forward"></i></a></span>
                    <span>Kiralık Araçlar</span>
                </p>
                <h1 class="mb-0 bread">Müsait Araçlar</h1>
            </div>
        </div>
    </div>
</section>
<section class="ftco-section bg-light">
    <div class="container">

        <div class="row justify-content-center mb-4">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <span class="subheading">Müsait Araçlar</span>
                <h2 class="mb-2">Seçilen Lokasyondaki Araçlar</h2>
            </div>
        </div>
        <div class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-4 ftco-animate">
                        <div class="car-wrap rounded mb-4">
                            <div class="img rounded d-flex align-items-end" style="background-image: url('@item.CarImageUrl');">
                            </div>
                            <div class="text">
                                <h2 class="mb-0">
                                    <a href="#">@item.CarName</a>
                                </h2>
                                <div class="d-flex mb-3 align-items-center">
                                    <span class="cat">
                                        <i class="ion-ios-pin"></i> @item.LocationName
                                    </span>
                                    <span class="ml-auto">
                                        <span style="background:#28a745; color:#fff; padding:6px 14px; border-radius:20px; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:5px; box-shadow:0 2px 6px rgba(40,167,69,0.35);">
                                            <i class="ion-ios-checkmark-circle" style="font-size:15px;"></i> Müsait
                                        </span>
                                    </span>
                                </div>
                                <p class="d-flex mb-0" style="gap:8px;">
                                    <a href="/Reservation/Index/@item.CarId" class="btn btn-primary py-2 flex-fill"
                                       style="border-radius:6px; font-weight:600; display:flex; align-items:center; justify-content:center; gap:6px; transition:transform .2s ease, box-shadow .2s ease;"
                                       onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 14px rgba(0,0,0,0.15)';"
                                       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
                                        <i class="ion-ios-calendar"></i> Rezervasyon Yap
                                    </a>
                                    <a href="#" class="btn btn-secondary py-2 flex-fill"
                                       style="border-radius:6px; font-weight:600; display:flex; align-items:center; justify-content:center; gap:6px; transition:transform .2s ease, box-shadow .2s ease;"
                                       onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 14px rgba(0,0,0,0.15)';"
                                       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
                                        <i class="ion-ios-information-circle-outline"></i> Detaylar
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-md-12 text-center ftco-animate">
                    <div class="p-5" style="background:#fff; border-radius:5px;">
                        <span class="ion-ios-car" style="font-size:60px; color:#ccc; display:block; margin-bottom:15px;"></span>
                        <h4 style="color:#999;">Bu lokasyonda müsait araç bulunamadı.</h4>
                        <p style="color:#bbb;">Farklı bir lokasyon veya tarih seçerek tekrar arayabilirsiniz.</p>
                        <a href="/Default/Index/" class="btn btn-primary mt-2">Geri Dön</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>