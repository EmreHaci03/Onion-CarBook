
@{
    ViewData["Title"] = "Index";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
@await Component.InvokeAsync("HeadUI")
<body>

    @await Component.InvokeAsync("NavBarUI")

    @await Component.InvokeAsync("DefaultBanner")


    @await Component.InvokeAsync("RentACarFilter")


    @await Component.InvokeAsync("DefaultLast5CarsWithBrands")

    @await Component.InvokeAsync("AboutUs")

    @await Component.InvokeAsync("ServiceList")


    @await Component.InvokeAsync("DefaultBecomeDriverCTA")

