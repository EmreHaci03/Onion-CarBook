@model List<ResultReviewDto>
<div class="rv-list">
    @foreach (var item in Model)
    {
        <div class="rv-card">
            <div class="rv-card-head">
                <div class="rv-avatar" style="background:#dbeafe;color:#1d4ed8;">@item.ReviewerName.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="rv-name">@item.ReviewerName</div>
                    <div class="rv-date">@item.CreatedDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="rv-card-stars">
                    <i class="ion-ios-star"></i><i class="ion-ios-star"></i>
                    <i class="ion-ios-star"></i><i class="ion-ios-star"></i>
                    <i class="ion-ios-star"></i>
                </div>
            </div>
            <p class="rv-text">@item.Comment</p>
            <div class="rv-footer">
                <span class="rv-tag"><i class="ion-ios-car"></i> 3 günlük kiralama</span>
                <span class="verified-badge"><i class="ion-ios-checkmark-circle"></i> Doğrulanmış kiracı</span>
                <span class="rv-helpful"><i class="ion-ios-thumbs-up"></i> Faydalı (12)</span>
            </div>
        </div>
    }
</div>

<!-- YORUM FORMU -->
<div style="margin-top:2rem; background:#f8f8f8; border:1px solid #ececec; border-radius:14px; padding:24px;">
    @if (User.Identity.IsAuthenticated)
    {
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.5rem;">
            <div style="width:36px; height:36px; background:#1d2127; border-radius:8px; display:flex; align-items:center; justify-content:center;">
                <i class="ion-ios-create" style="font-size:18px; color:#fbb710;"></i>
            </div>
            <div>
                <h4 style="font-size:16px; font-weight:700; color:#1d2127; margin:0;">Değerlendirme Yap</h4>
                <p style="font-size:12px; color:#888; margin:0;">Deneyiminizi paylaşın</p>
            </div>
        </div>

        <form method="post" asp-controller="Car" asp-action="AddReview">
            <input type="hidden" name="CarId" value="@ViewBag.CarId" />

            <div style="margin-bottom:14px;">
                <label style="font-size:12px; font-weight:600; color:#444; display:block; margin-bottom:6px;">
                    <i class="ion-ios-person" style="color:#aaa;"></i> Ad Soyad
                </label>
                <input type="text" name="ReviewerName" placeholder="Ahmet Yılmaz"
                       style="width:100%; padding:10px 14px; border:1px solid #e2e2e2; border-radius:8px; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box; background:#fff;"
                       onfocus="this.style.borderColor='#fbb710';" onblur="this.style.borderColor='#e2e2e2';" />
            </div>

            <div style="margin-bottom:14px;">
                <label style="font-size:12px; font-weight:600; color:#444; display:block; margin-bottom:6px;">
                    <i class="ion-ios-star" style="color:#aaa;"></i> Puanınız
                </label>
                <select name="Rating"
                        style="width:100%; padding:10px 14px; border:1px solid #e2e2e2; border-radius:8px; font-size:13px; font-family:inherit; outline:none; background:#fff;">
                    <option value="5">⭐⭐⭐⭐⭐ Mükemmel</option>
                    <option value="4">⭐⭐⭐⭐ Çok İyi</option>
                    <option value="3">⭐⭐⭐ İyi</option>
                    <option value="2">⭐⭐ Orta</option>
                    <option value="1">⭐ Kötü</option>
                </select>
            </div>

            <div style="margin-bottom:14px;">
                <label style="font-size:12px; font-weight:600; color:#444; display:block; margin-bottom:6px;">
                    <i class="ion-ios-chatbubbles" style="color:#aaa;"></i> Yorumunuz
                </label>
                <textarea name="Comment" rows="4" placeholder="Araç hakkındaki düşüncelerinizi paylaşın..."
                      style="width:100%; padding:10px 14px; border:1px solid #e2e2e2; border-radius:8px; font-size:13px; font-family:inherit; outline:none; box-sizing:border-box; resize:vertical; background:#fff;"
                      onfocus="this.style.borderColor='#fbb710';" onblur="this.style.borderColor='#e2e2e2';"></textarea>
            </div>

            <div style="text-align:right;">
                <button type="submit"
                        style="display:inline-flex; align-items:center; gap:6px; padding:11px 24px; background:#fbb710; color:#1d2127; border:none; border-radius:8px; font-size:13px; font-weight:700; cursor:pointer; font-family:inherit;"
                        onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
                    <i class="ion-ios-send"></i> Gönder
                </button>
            </div>
        </form>
    }
    else
    {
        <div style="text-align:center; padding:1.5rem 0;">
            <i class="ion-ios-lock" style="font-size:36px; color:#cbd5e1; display:block; margin-bottom:12px;"></i>
            <p style="font-size:14px; color:#64748b; margin:0 0 1.2rem;">Değerlendirme yapmak için giriş yapmanız gerekiyor.</p>
            <div style="display:flex; gap:10px; justify-content:center;">
                <a href="/Login/Index"
                   style="padding:10px 24px; background:#fbb710; color:#1d2127; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none;">
                    Giriş Yap
                </a>
                <a href="/Register/Index"
                   style="padding:10px 24px; background:#fff; color:#fbb710; border:1px solid #fbb710; border-radius:8px; font-size:13px; font-weight:700; text-decoration:none;">
                    Kayıt Ol
                </a>
            </div>
        </div>
    }
</div>