@model GetBlogByIdDto

@if(Model!=null){
<div class="col-md-8 ftco-animate">

    <div style="margin-bottom: 2rem;">
        <img src="@Model.CoverImageUrl" alt="@Model.Title" class="img-fluid" style="width:100%; border-radius:12px; object-fit:cover; max-height:420px;" />
    </div>

    <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.5rem; flex-wrap:wrap;">
        <span style="display:inline-flex; align-items:center; gap:6px; background:#eff6ff; color:#1d4ed8; border-radius:20px; padding:4px 12px; font-size:12px; font-weight:500;">
            <i class="bi bi-tag"></i> @Model.BlogCategoryName
        </span>
        <span style="display:inline-flex; align-items:center; gap:6px; color:#64748b; font-size:13px;">
            <i class="bi bi-calendar3"></i> @Model.CreateDate.ToString("dd MMMM yyyy")
        </span>
        <span style="display:inline-flex; align-items:center; gap:6px; color:#64748b; font-size:13px;">
            <i class="bi bi-person"></i> @Model.AuthorName
        </span>
    </div>

    <h1 style="font-size:2rem; font-weight:700; color:#0f172a; line-height:1.3; margin-bottom:1.5rem;">@Model.Title</h1>

    <div style="font-size:1rem; color:#374151; line-height:1.9;">
        <p>@Model.Description</p>
    </div>

    <hr style="border:none; border-top:1px solid #e2e8f0; margin:2.5rem 0;" />

    @await Component.InvokeAsync("BlogDetailAuthorAbout", new { authorId = Model.AuthorId })

    <div class="pt-5 mt-5">
        @await Component.InvokeAsync("BlogComments", new { id = Model.Id })
        @await Component.InvokeAsync("BlogCommentForm", new { id = Model.Id })
    </div>
</div>
}