@model List<GetBlogCountByCategory>

<style>
    .category-list-box h3 {
        font-size: 18px;
        font-weight: 700;
        color: #1d2127;
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 2px solid #f0f0f0;
    }

    .category-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .category-list-item {
        margin-bottom: 6px;
    }

        .category-list-item a {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 11px 14px;
            border-radius: 8px;
            color: #444;
            font-size: 14.5px;
            font-weight: 500;
            text-decoration: none;
            transition: background .25s ease, color .25s ease, padding-left .25s ease;
        }

            .category-list-item a:hover {
                background: #faf7f0;
                color: #1d2127;
                padding-left: 20px;
                text-decoration: none;
            }

    .category-count-badge {
        background: #f0f0f0;
        color: #888;
        font-size: 12px;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 12px;
        transition: background .25s ease, color .25s ease;
    }

    .category-list-item a:hover .category-count-badge {
        background: #fbb710;
        color: #1d2127;
    }
</style>

<div class="sidebar-box category-list-box ftco-animate">
    <h3>Kategoriler</h3>
    <ul class="category-list">
        @foreach (var item in Model)
        {
            <li class="category-list-item">
                <a href="#">
                    @item.CategoryName
                    <span class="category-count-badge">@item.BlogCount</span>
                </a>
            </li>
        }
    </ul>
</div>