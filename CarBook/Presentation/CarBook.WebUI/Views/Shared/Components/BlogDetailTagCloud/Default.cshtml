@model List<GetByBlogIdTagCloudDto>

<style>
    .tag-cloud-box h3 {
        font-size: 18px;
        font-weight: 700;
        color: #1d2127;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 2px solid #f0f0f0;
    }

    .tagcloud {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tag-cloud-link {
        display: inline-block;
        background: #f5f5f5;
        color: #555;
        font-size: 12.5px;
        font-weight: 600;
        padding: 7px 16px;
        border-radius: 20px;
        text-decoration: none;
        transition: background .25s ease, color .25s ease, transform .2s ease;
    }

        .tag-cloud-link:hover {
            background: #fbb710;
            color: #1d2127;
            transform: translateY(-2px);
            text-decoration: none;
        }
</style>

<div class="sidebar-box tag-cloud-box ftco-animate">
    <h3>Etiket Bulutu</h3>
    <div class="tagcloud">
        @foreach (var item in Model)
        {
            <a href="#" class="tag-cloud-link">@item.TagCloudName</a>
        }
    </div>
</div>