@model List<ResultBannerDto>

<style>
    .hero-banner-wrap {
        position: relative;
        background-size: cover;
        background-position: center;
        min-height: 640px;
        display: flex;
        align-items: center;
    }

        .hero-banner-wrap .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(13,15,18,0.55), rgba(13,15,18,0.78));
        }

    .hero-banner-badge {
        display: inline-block;
        background: rgba(251,183,16,0.15);
        border: 1px solid #fbb710;
        color: #fbb710;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 7px 20px;
        border-radius: 24px;
        margin-bottom: 24px;
    }

    .hero-banner-title {
        color: #fff;
        font-size: 48px;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 20px;
    }

    .hero-banner-desc {
        color: #d8d9db;
        font-size: 18px;
        line-height: 1.8;
        max-width: 640px;
        margin: 0 auto 36px;
    }

    .hero-play-wrap {
        display: inline-flex;
        align-items: center;
        gap: 22px;
        text-decoration: none;
    }

        .hero-play-wrap:hover {
            text-decoration: none;
        }

    .hero-play-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #fbb710;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #1d2127;
        transition: transform .3s ease, box-shadow .3s ease;
        box-shadow: 0 0 0 0 rgba(251,183,16,0.5);
        flex-shrink: 0;
    }

        .hero-play-icon::before {
            content: '';
            position: absolute;
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: 2px solid rgba(251,183,16,0.5);
            animation: heroPulse 2s ease-out infinite;
        }

    @@keyframes heroPulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        100% {
            transform: scale(1.5);
            opacity: 0;
        }
    }

    .hero-play-wrap:hover .hero-play-icon {
        transform: scale(1.08);
    }

    .hero-play-text {
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        text-align: left;
    }

    @@media (max-width: 767px) {
        .hero-banner-title {
            font-size: 30px;
        }

        .hero-banner-desc {
            font-size: 15px;
        }

        .hero-banner-wrap {
            min-height: 480px;
        }
    }
</style>

<div class="hero-banner-wrap" style="background-image: url('/carbook-master/images/bg_1.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container" style="position: relative; z-index: 2;">
        @foreach (var item in Model)
        {
            <div class="row justify-content-center">
                <div class="col-lg-8 ftco-animate text-center">
                    <span class="hero-banner-badge">Güvenilir Araç Kiralama</span>
                    <h1 class="hero-banner-title">@item.Title</h1>
                    <p class="hero-banner-desc">@item.Description</p>

                    <a href="@item.VideoUrl" class="hero-play-wrap popup-vimeo">
                        <span class="hero-play-icon" style="position: relative;">
                            <i class="ion-ios-play"></i>
                        </span>
                        <span class="hero-play-text">@item.VideoDescription</span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>