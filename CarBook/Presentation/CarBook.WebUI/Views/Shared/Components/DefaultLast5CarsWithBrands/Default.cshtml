@model List<ResultLast5CarsWithBrandsDto>

<style>
    .featured-car-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 24px rgba(0,0,0,0.07);
        margin: 8px 12px 30px;
        transition: transform .3s ease, box-shadow .3s ease;
    }

        .featured-car-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 36px rgba(0,0,0,0.12);
        }

    .featured-car-img {
        height: 200px;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .featured-car-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        background: #fbb710;
        color: #1d2127;
        font-size: 11.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 5px 12px;
        border-radius: 16px;
    }

    .featured-car-body {
        padding: 20px 22px 22px;
    }

    .featured-car-brand {
        font-size: 12.5px;
        font-weight: 600;
        color: #fbb710;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .featured-car-title {
        font-size: 19px;
        font-weight: 700;
        color: #1d2127;
        margin: 4px 0 14px;
    }

    .featured-car-price-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 18px;
        padding-bottom: 18px;
        border-bottom: 1px solid #f0f0f0;
    }

    .featured-car-price {
        font-size: 22px;
        font-weight: 700;
        color: #1d2127;
    }

    .featured-car-price-unit {
        font-size: 13px;
        color: #999;
    }

    .featured-car-actions {
        display: flex;
        gap: 8px;
    }

        .featured-car-actions a {
            flex: 1;
            text-align: center;
            border-radius: 6px;
            font-weight: 600;
            font-size: 14px;
            padding: 10px 0;
            transition: transform .2s ease, box-shadow .2s ease;
            text-decoration: none;
        }

            .featured-car-actions a:hover {
                transform: translateY(-2px);
                text-decoration: none;
            }

    .featured-car-btn-primary {
        background: #fbb710;
        color: #1d2127;
    }

        .featured-car-btn-primary:hover {
            color: #1d2127;
            box-shadow: 0 8px 18px rgba(251,183,16,0.35);
        }

    .featured-car-btn-secondary {
        background: #f4f4f4;
        color: #1d2127;
    }

        .featured-car-btn-secondary:hover {
            color: #1d2127;
            box-shadow: 0 8px 18px rgba(0,0,0,0.1);
        }
</style>

<section class="ftco-section ftco-no-pt bg-light">
    <div class="container">

        <div class="row justify-content-center">
            <div class="col-md-12 heading-section text-center ftco-animate mb-5">
                <span class="subheading" style="color:#fbb710">Sizler İçin Seçtiklerimiz</span>
                <h2 class="mb-2">Öne Çıkan Araçlar</h2>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="carousel-car owl-carousel">
                    @foreach (var item in Model)
                    {
                        var dailyPrice = item.Pricings?.FirstOrDefault(x => x.PricingName == "Günlük")?.Amount;
                        <div class="item">
                            <div class="featured-car-card">
                                <div class="featured-car-img" style="background-image:url('@item.MainImageUrl');">
                                    <span class="featured-car-badge">Öne Çıkan</span>
                                </div>
                                <div class="featured-car-body">
                                    <div class="featured-car-brand">@item.BrandName</div>
                                    <h3 class="featured-car-title">@item.Model</h3>

                                    <div class="featured-car-price-row">
                                        <span class="featured-car-price">@dailyPrice ₺</span>
                                        <span class="featured-car-price-unit">/ günlük</span>
                                    </div>

                                    <div class="featured-car-actions">
                                        <a href="/Reservation/Index/@item.Id" class="featured-car-btn-primary">
                                            <i class="ion-ios-calendar"></i> Kirala
                                        </a>
                                        <a href="/Car/CarDetail/@item.Id" class="featured-car-btn-secondary">
                                            <i class="ion-ios-information-circle-outline"></i> Detay
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</section>