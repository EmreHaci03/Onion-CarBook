@model List<GetLast3BlogsWithAuthorDto>
@{
    var commentCounts = ViewBag.CommentCounts as Dictionary<int, int>;
}
<style>
    .sidebar-box h3 {
        font-size: 18px;
        font-weight: 700;
        color: #1d2127;
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 2px solid #f0f0f0;
    }

    .recent-blog-item {
        display: flex;
        gap: 16px;
        padding: 10px;
        border-radius: 10px;
        transition: background .25s ease;
        align-items: flex-start;
    }

        .recent-blog-item:hover {
            background: #f9f9f9;
        }

    .recent-blog-img {
        width: 80px;
        height: 80px;
        min-width: 80px;
        border-radius: 8px;
        background-size: cover;
        background-position: center;
        display: block;
        transition: transform .25s ease;
    }

    .recent-blog-item:hover .recent-blog-img {
        transform: scale(1.05);
    }

    .recent-blog-title {
        font-size: 14.5px;
        font-weight: 700;
        color: #1d2127;
        line-height: 1.5;
        margin-bottom: 8px;
    }

        .recent-blog-title a {
            color: inherit;
            text-decoration: none;
        }

            .recent-blog-title a:hover {
                color: #fbb710;
                text-decoration: none;
            }

    .recent-blog-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font-size: 11.5px;
        color: #999;
    }

        .recent-blog-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .recent-blog-meta i {
            color: #fbb710;
            font-size: 12px;
        }
</style>

<div class="sidebar-box ftco-animate">
    <h3>Son Bloglar</h3>
    @foreach (var item in Model)
    {
        var count = commentCounts != null && commentCounts.ContainsKey(item.Id) ? commentCounts[item.Id] : 0;
        <div class="recent-blog-item mb-2">
            <a href="/Blog/BlogDetail/@item.Id" class="recent-blog-img" style="background-image:url('@item.CoverImageUrl');"></a>
            <div class="text">
                <h3 class="recent-blog-title">
                    <a href="/Blog/BlogDetail/@item.Id">@item.Title</a>
                </h3>
                <div class="recent-blog-meta">
                    <span><i class="ion-ios-calendar"></i>@item.CreateDate.ToShortDateString()</span>
                    <span><i class="ion-ios-person"></i>@item.AuthorName</span>
                    <span><i class="ion-ios-chatbubbles"></i>@count </span>
                </div>
            </div>
        </div>
    }
</div>