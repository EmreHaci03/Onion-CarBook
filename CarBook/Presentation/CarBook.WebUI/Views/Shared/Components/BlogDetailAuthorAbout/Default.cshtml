@model GetAuthorByIdDto

<div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:14px; padding:20px; display:flex; align-items:center; gap:18px; margin:2rem 0;">
    <img src="@Model.ImageUrl" alt="@Model.AuthorName" style="width:70px; height:70px; border-radius:50%; object-fit:cover; flex-shrink:0; border:3px solid #fff; box-shadow:0 2px 8px rgba(0,0,0,.1);" />
    <div>
        <div style="font-size:11px; color:#94a3b8; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Yazar Hakkında</div>
        <h4 style="font-size:16px; font-weight:600; color:#0f172a; margin:0 0 6px;">@Model.AuthorName</h4>
        <p style="font-size:13px; color:#64748b; margin:0; line-height:1.6;">@Model.Description</p>
    </div>
</div>
