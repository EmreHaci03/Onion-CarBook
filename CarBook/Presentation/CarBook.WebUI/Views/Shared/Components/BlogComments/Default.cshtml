@model List<GetCommentByBlogIdDto>
<div class="pt-5">
    <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.5rem;">
        <div style="width:36px; height:36px; background:linear-gradient(135deg,#3b82f6,#6366f1); border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <i class="bi bi-chat-dots-fill" style="font-size:16px; color:#fff;"></i>
        </div>
        <h3 style="font-size:18px; font-weight:600; color:#0f172a; margin:0;">
            Yorumlar <span style="font-size:14px; font-weight:400; color:#64748b;">(@(Model?.Count ?? 0) yorum)</span>
        </h3>
    </div>

    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div style="display:flex; gap:14px; padding:18px 0; border-bottom:1px solid #f1f5f9;">
                <div style="width:42px; height:42px; background:linear-gradient(135deg,#eff6ff,#dbeafe); border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <span style="font-size:16px; font-weight:600; color:#3b82f6;">@item.Name?.Substring(0, 1).ToUpper()</span>
                </div>
                <div style="flex:1;">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;">
                        <span style="font-size:14px; font-weight:600; color:#0f172a;">@item.Name</span>
                        <span style="font-size:11px; color:#94a3b8;">
                            <i class="bi bi-clock" style="font-size:11px;"></i>
                            @item.CreatedDate.ToString("dd MMM yyyy")
                        </span>
                    </div>
                    <p style="font-size:13px; color:#374151; line-height:1.7; margin:0;">@item.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <div style="background:#f8fafc; border:1px dashed #e2e8f0; border-radius:12px; padding:2.5rem; text-align:center;">
            <i class="bi bi-chat" style="font-size:32px; color:#cbd5e1; display:block; margin-bottom:10px;"></i>
            <p style="font-size:14px; color:#94a3b8; margin:0;">Henüz yorum yapılmamış. İlk yorumu siz yapın!</p>
        </div>
    }

    <!-- YORUM FORMU -->
    <div style="margin-top:2rem; background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:1.5rem;">
        @if (User.Identity.IsAuthenticated)
        {
            <h4 style="font-size:15px; font-weight:600; color:#0f172a; margin:0 0 1rem;">Yorum yap</h4>
            <form method="post" asp-controller="Blog" asp-action="AddComment">
                <input type="hidden" name="BlogId" value="@ViewBag.BlogId" />
                <div style="margin-bottom:12px;">
                    <input type="text" name="Name" placeholder="Adınız"
                           style="width:100%; padding:10px 14px; border:1px solid #e2e8f0; border-radius:8px; font-size:13px; background:#fff; box-sizing:border-box; outline:none;" />
                </div>
                <div style="margin-bottom:12px;">
                    <textarea name="Content" rows="4" placeholder="Yorumunuzu yazın..."
                          style="width:100%; padding:10px 14px; border:1px solid #e2e8f0; border-radius:8px; font-size:13px; background:#fff; box-sizing:border-box; outline:none; resize:vertical;"></textarea>
                </div>
                <button type="submit"
                        style="padding:10px 24px; background:#3b82f6; color:#fff; border:none; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer;">
                    Gönder
                </button>
            </form>
        }
        else
        {
            <div style="text-align:center; padding:1rem 0;">
                <i class="bi bi-lock" style="font-size:28px; color:#cbd5e1; display:block; margin-bottom:10px;"></i>
                <p style="font-size:14px; color:#64748b; margin:0 0 1rem;">Yorum yapmak için giriş yapmanız gerekiyor.</p>
                <div style="display:flex; gap:10px; justify-content:center;">
                    <a href="/Login/Index"
                       style="display:inline-block; padding:10px 24px; background:#3b82f6; color:#fff; border-radius:8px; font-size:13px; font-weight:600; text-decoration:none;">
                        Giriş Yap
                    </a>
                    <a href="/Register/Index"
                       style="display:inline-block; padding:10px 24px; background:#fff; color:#3b82f6; border:1px solid #3b82f6; border-radius:8px; font-size:13px; font-weight:600; text-decoration:none;">
                        Kayıt Ol
                    </a>
                </div>
            </div>
        }
    </div>
</div>