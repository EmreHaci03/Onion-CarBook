@model List<ResultCarWithPricingDto>
@{
    ViewData["Title"] = "Arabalarımız";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
@section HeroBanner {
    <style>
        .page-hero-wrap {
            position: relative;
        }

            .page-hero-wrap .overlay {
                background: linear-gradient(180deg, rgba(13,15,18,0.5), rgba(13,15,18,0.82));
            }

        .page-breadcrumbs {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            padding: 8px 18px;
            border-radius: 24px;
            font-size: 13px;
            margin-bottom: 22px;
        }

            .page-breadcrumbs a {
                color: #d8d9db;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                transition: color .2s ease;
            }

                .page-breadcrumbs a:hover {
                    color: #fbb710;
                    text-decoration: none;
                }

            .page-breadcrumbs .current {
                color: #fbb710;
                font-weight: 600;
            }

            .page-breadcrumbs .sep {
                color: #5f646b;
            }

        .page-hero-title {
            color: #fff;
            font-size: 46px;
            font-weight: 800;
            letter-spacing: -0.5px;
            position: relative;
            display: inline-block;
            padding-bottom: 18px;
        }

            .page-hero-title::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: 0;
                width: 60px;
                height: 4px;
                background: #fbb710;
                border-radius: 2px;
            }

        @@media (max-width: 767px) {
            .page-hero-title {
                font-size: 30px;
            }
        }
    </style>

    <section class="hero-wrap hero-wrap-2 page-hero-wrap js-fullheight" style="background-image: url('/carbook-master/images/bg_2.jpg');">
        <div class="overlay"></div>
        <div class="container">
            <div class="row no-gutters slider-text js-fullheight align-items-end">
                <div class="col-md-9 pb-5">
                    <div class="page-breadcrumbs">
                        <a href="/Default/Index/"><i class="ion-ios-home"></i> Ana Sayfa</a>
                        <span class="sep">/</span>
                        <span class="current">Arabalarımız</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
<style>
    .car-list-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #fff;
        border-radius: 10px;
        padding: 18px 24px;
        margin-bottom: 32px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.05);
    }

    .car-list-count {
        font-size: 14.5px;
        color: #666;
    }

        .car-list-count strong {
            color: #1d2127;
        }

    .car-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 24px rgba(0,0,0,0.07);
        margin-bottom: 28px;
        transition: transform .3s ease, box-shadow .3s ease;
    }

        .car-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 36px rgba(0,0,0,0.12);
        }

    .car-card-img {
        height: 210px;
        background-size: cover;
        background-position: center;
    }

    .car-card-body {
        padding: 20px 22px 22px;
    }

    .car-card-brand {
        font-size: 12.5px;
        font-weight: 600;
        color: #fbb710;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .car-card-title {
        font-size: 19px;
        font-weight: 700;
        color: #1d2127;
        margin: 4px 0 14px;
    }

        .car-card-title a {
            color: inherit;
            text-decoration: none;
        }

            .car-card-title a:hover {
                color: #fbb710;
                text-decoration: none;
            }

    .car-card-price-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 18px;
        padding-bottom: 18px;
        border-bottom: 1px solid #f0f0f0;
    }

    .car-card-price {
        font-size: 22px;
        font-weight: 700;
        color: #1d2127;
    }

    .car-card-price-unit {
        font-size: 13px;
        color: #999;
    }

    .car-card-actions {
        display: flex;
        gap: 8px;
    }

        .car-card-actions a {
            flex: 1;
            text-align: center;
            border-radius: 6px;
            font-weight: 600;
            font-size: 14px;
            padding: 10px 0;
            transition: transform .2s ease, box-shadow .2s ease;
            text-decoration: none;
        }

            .car-card-actions a:hover {
                transform: translateY(-2px);
                text-decoration: none;
            }

    .car-card-btn-primary {
        background: #fbb710;
        color: #1d2127;
    }

        .car-card-btn-primary:hover {
            color: #1d2127;
            box-shadow: 0 8px 18px rgba(251,183,16,0.35);
        }

    .car-card-btn-secondary {
        background: #f4f4f4;
        color: #1d2127;
    }

        .car-card-btn-secondary:hover {
            color: #1d2127;
            box-shadow: 0 8px 18px rgba(0,0,0,0.1);
        }

    .car-pagination {
        display: flex;
        justify-content: center;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 20px 0 0;
    }

        .car-pagination li a, .car-pagination li span {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            border-radius: 8px;
            background: #fff;
            color: #1d2127;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            border: 1px solid #ececec;
            transition: all .2s ease;
        }

            .car-pagination li a:hover {
                background: #fbb710;
                border-color: #fbb710;
                color: #1d2127;
                text-decoration: none;
            }

        .car-pagination li.active span {
            background: #1d2127;
            border-color: #1d2127;
            color: #fff;
        }
</style>

<section class="ftco-section bg-light">
    <div class="container">

        <div class="car-list-toolbar ftco-animate">
            <span class="car-list-count">Toplam <strong>@Model.Count</strong> araç listeleniyor</span>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                var dailyPrice = item.Pricings?.FirstOrDefault(x => x.PricingName == "Günlük")?.Amount;
                <div class="col-md-4">
                    <div class="car-card ftco-animate">
                        <div class="car-card-img" style="background-image:url('@item.MainImageUrl');"></div>
                        <div class="car-card-body">
                            <div class="car-card-brand">@item.BrandName</div>
                            <h2 class="car-card-title"><a href="car-single.html">@item.Model</a></h2>

                            <div class="car-card-price-row">
                                <span class="car-card-price">@dailyPrice ₺</span>
                                <span class="car-card-price-unit">/ günlük</span>
                            </div>

                            <div class="car-card-actions">
                                <a href="/Reservation/Index/@item.Id" class="car-card-btn-primary">
                                    <i class="ion-ios-calendar"></i> Kirala
                                </a>
                                <a href="/Car/CarDetail/@item.Id" class="car-card-btn-secondary">
                                    <i class="ion-ios-information-circle-outline"></i> Detaylar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row mt-3">
            <div class="col text-center">
                <ul class="car-pagination">
                    <li><a href="#"><i class="ion-ios-arrow-back"></i></a></li>
                    <li class="active"><span>1</span></li>
                    <li><a href="#">2</a></li>
                    <li><a href="#">3</a></li>
                    <li><a href="#">4</a></li>
                    <li><a href="#">5</a></li>
                    <li><a href="#"><i class="ion-ios-arrow-forward"></i></a></li>
                </ul>
            </div>
        </div>

    </div>
</section>