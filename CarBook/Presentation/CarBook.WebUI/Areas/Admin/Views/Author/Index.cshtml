@model List<ResultAuthorDto>
@{
    ViewData["Title"] = "Yazar Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddAuthor", "Author", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .author-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 14px;
    }

    .author-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow .2s, border-color .2s, transform .2s;
        position: relative;
        overflow: hidden;
    }

        .author-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #3b82f6, #8b5cf6);
            opacity: 0;
            transition: opacity .2s ease;
        }

        .author-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

            .author-card:hover::before {
                opacity: 1;
            }

    .author-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid #e2e8f0;
    }

    .author-avatar-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 18px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .author-info {
        flex: 1;
        min-width: 0;
    }

    .author-name {
        font-size: 14.5px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .author-desc {
        font-size: 12px;
        color: #64748b;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .author-actions {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex-shrink: 0;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #475569;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #2563eb;
            text-decoration: none;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            text-decoration: none;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) yazar</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="author-grid">
        @foreach (var item in Model)
        {
            <div class="author-card">
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="@item.AuthorName" class="author-avatar" />
                }
                else
                {
                    <div class="author-avatar-placeholder">@item.AuthorName?.Substring(0, 1).ToUpper()</div>
                }
                <div class="author-info">
                    <div class="author-name">@item.AuthorName</div>
                    <div class="author-desc">@item.Description</div>
                </div>
                <div class="author-actions">
                    <a asp-area="Admin" asp-controller="Author" asp-action="UpdateAuthor" asp-route-id="@item.Id" class="btn-edit" title="Düzenle">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-area="Admin" asp-controller="Author" asp-action="DeleteAuthor" asp-route-id="@item.Id" class="btn-delete" title="Sil">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-person" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz yazar eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk yazarı ekleyin.</div>
        <a asp-area="Admin" asp-controller="Author" asp-action="AddAuthor"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#8b5cf6); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Yazar Ekle
        </a>
    </div>
}
