@model List<ResultCarPricingDto>

@{
    ViewData["Title"] = "Araç Fiyatlandırmaları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 18px;
    }

    .pricing-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        transition: all .2s ease;
        position: relative;
    }

        .pricing-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
            border-color: #c7d2fe;
        }

    .pricing-header {
        padding: 14px 16px;
        background: linear-gradient(135deg, #111827, #1f2937);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pricing-title {
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .pricing-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        background: #facc15;
        color: #111827;
    }

    .pricing-body {
        padding: 18px;
        text-align: center;
    }

    .pricing-amount {
        font-size: 30px;
        font-weight: 800;
        color: #2563eb;
        margin-bottom: 8px;
    }

    .pricing-desc {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 16px;
    }

    .pricing-actions {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        flex: 1;
        padding: 8px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: .15s;
        cursor: pointer;
        border: none;
    }

    .btn-edit {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
    }

        .btn-edit:hover {
            background: #dbeafe;
        }

    .btn-delete {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fee2e2;
        }

    .btn-add {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .header-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
    }
</style>

<div class="header-wrap">
    <div class="page-title">🚗 Araç Fiyatlandırmaları</div>
    <a asp-action="AddCarPricing" class="btn-add">
        <i class="bi bi-plus-lg"></i> Yeni Ekle
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="pricing-grid">
        @foreach (var item in Model)
        {
            <div class="pricing-card">
                <div class="pricing-header">
                    <div class="pricing-title">
                        🚘 @item.CarWithModel
                    </div>
                    <div class="pricing-badge">@item.PricingType</div>
                </div>
                <div class="pricing-body">
                    <div class="pricing-amount">@item.Amount.ToString("C")</div>
                    <div class="pricing-desc">
                        @item.CarWithModel için <b>@item.PricingType</b> fiyatı
                    </div>
                    <div class="pricing-actions">
                        <a asp-action="UpdateCarPricing"
                           asp-route-id="@item.Id"
                           class="btn-action btn-edit">
                            ✏️ Düzenle
                        </a>
                        <button class="btn-action btn-delete"
                                onclick="deletePricing(@item.Id, this, '@Html.Raw(item.CarWithModel)', '@Html.Raw(item.PricingType)', '@item.Amount.ToString("C")')">
                            🗑 Sil
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div style="text-align:center; padding:60px; color:#94a3b8;">
        <div style="font-size:48px;">📉</div>
        <h5>Henüz fiyatlandırma yok</h5>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    async function deletePricing(id, el, carName, pricingType, amount) {

        const result = await Swal.fire({
            width: 440,
            padding: "2rem 2rem 1.5rem",
            showCancelButton: true,
            showConfirmButton: true,
            confirmButtonText: "Evet, sil",
            cancelButtonText: "Vazgeç",
            customClass: {
                popup: 'swal-custom-popup',
                confirmButton: 'swal-btn-confirm',
                cancelButton: 'swal-btn-cancel',
                actions: 'swal-custom-actions'
            },
            buttonsStyling: false,
            html: `
                <div style="display:flex;flex-direction:column;align-items:center;gap:0">
                    <div style="width:60px;height:60px;border-radius:50%;background:#FEE2E2;
                         display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                             stroke="#DC2626" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6l-1 14H6L5 6"/>
                            <path d="M10 11v6M14 11v6"/>
                            <path d="M9 6V4h6v2"/>
                        </svg>
                    </div>
                    <p style="font-size:17px;font-weight:700;color:#111827;margin:0 0 .35rem">Bu kayıt silinecek</p>
                    <p style="font-size:13px;color:#6b7280;margin:0 0 1.25rem;line-height:1.6">
                        Aşağıdaki fiyatlandırma kaydı kalıcı olarak kaldırılacak.
                    </p>

                    <div style="width:100%;background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;
                         padding:.75rem 1rem;margin-bottom:.9rem;box-sizing:border-box;
                         display:flex;align-items:center;gap:10px">
                        <div style="width:38px;height:38px;border-radius:10px;background:#1e293b;
                             display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                 stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="3" width="15" height="13" rx="2"/>
                                <path d="M16 8h4l3 4v3h-7V8z"/>
                                <circle cx="5.5" cy="18.5" r="2.5"/>
                                <circle cx="18.5" cy="18.5" r="2.5"/>
                            </svg>
                        </div>
                        <div style="text-align:left;flex:1">
                            <div style="font-size:14px;font-weight:600;color:#111827;line-height:1.3">${carName}</div>
                            <div style="font-size:12px;color:#64748b;margin-top:2px">${pricingType}</div>
                        </div>
                        <div style="font-size:15px;font-weight:700;color:#2563eb;flex-shrink:0">${amount}</div>
                    </div>

                    <div style="width:100%;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;
                         padding:.5rem .85rem;box-sizing:border-box;
                         display:flex;align-items:center;gap:7px">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                             stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <span style="font-size:12px;color:#dc2626;font-weight:500">Bu işlem geri alınamaz.</span>
                    </div>
                </div>
            `
        });

        if (!result.isConfirmed) return;

        try {
            const response = await fetch('/Admin/CarPricing/DeleteCarPricing?id=' + id, {
                method: 'POST'
            });

            if (!response.ok) throw new Error();

            const card = el.closest('.pricing-card');
            card.style.transition = "all .3s ease";
            card.style.transform = "scale(.95)";
            card.style.opacity = "0";
            setTimeout(() => card.remove(), 300);

            await Swal.fire({
                html: `
                    <div style="display:flex;flex-direction:column;align-items:center;padding:.5rem 0">
                        <div style="width:56px;height:56px;border-radius:50%;background:#DCFCE7;
                             display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
                                 stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <p style="font-size:16px;font-weight:700;color:#111827;margin:0 0 .3rem">Kayıt silindi</p>
                        <p style="font-size:13px;color:#6b7280;margin:0">${carName} fiyatlandırması kaldırıldı.</p>
                    </div>
                `,
                showConfirmButton: false,
                timer: 1800,
                width: 360,
                padding: "1.5rem"
            });

        } catch (e) {
            Swal.fire({
                html: `
                    <div style="display:flex;flex-direction:column;align-items:center;padding:.5rem 0">
                        <div style="width:56px;height:56px;border-radius:50%;background:#FEE2E2;
                             display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
                                 stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"/>
                                <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </div>
                        <p style="font-size:16px;font-weight:700;color:#111827;margin:0 0 .3rem">Hata oluştu</p>
                        <p style="font-size:13px;color:#6b7280;margin:0">Silme işlemi başarısız oldu, tekrar deneyin.</p>
                    </div>
                `,
                showConfirmButton: true,
                confirmButtonText: "Tamam",
                customClass: { confirmButton: 'swal-btn-confirm' },
                buttonsStyling: false,
                width: 360,
                padding: "1.5rem"
            });
        }
    }
</script>

<style>
    .swal-custom-popup {
        border-radius: 20px !important;
        font-family: inherit !important;
    }

    .swal-custom-actions {
        gap: 10px !important;
        margin-top: 1.25rem !important;
        padding: 0 !important;
        width: 100% !important;
    }

    .swal-btn-cancel {
        flex: 1;
        padding: 10px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-size: 14px;
        font-weight: 600;
        color: #475569;
        cursor: pointer;
        transition: background .15s;
    }

        .swal-btn-cancel:hover {
            background: #f1f5f9;
        }

    .swal-btn-confirm {
        flex: 1.4;
        padding: 10px 16px;
        border-radius: 10px;
        border: none;
        background: #DC2626;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        transition: background .15s, transform .1s;
    }

        .swal-btn-confirm:hover {
            background: #B91C1C;
        }

        .swal-btn-confirm:active {
            transform: scale(.97);
        }
</style>