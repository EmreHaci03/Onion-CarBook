@model CreateBrandDto
@{
    ViewData["Title"] = "Marka Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        margin-bottom: 16px;
        transition: color .15s;
    }

        .back-btn:hover {
            color: #374151;
        }

    .add-wrap {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 22px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-card-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .form-card-icon i {
            font-size: 18px;
            color: #3b82f6;
        }

    .form-card-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .form-card-body {
        padding: 22px;
    }

    .field-group {
        margin-bottom: 18px;
    }

    .field-label {
        font-size: 11.5px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 13px;
        color: #0f172a;
        font-family: 'Segoe UI', sans-serif;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        background: #fafafa;
        box-sizing: border-box;
    }

        .form-control:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            background: #fff;
        }

    .text-danger {
        font-size: 11px;
        color: #dc2626;
        display: block;
        margin-top: 3px;
    }

    .divider {
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 18px 0;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #374151;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #fff;
        cursor: pointer;
        transition: opacity .15s;
    }

        .btn-save:hover {
            opacity: .9;
        }

    .side-card {
        background: #fafafa;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 22px;
    }

    .side-card-title {
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .side-card-title i {
            color: #3b82f6;
        }

    .preview-brand-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
        min-height: 84px;
    }

    .preview-avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
    }

    .preview-brand-name {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .preview-empty {
        font-size: 12.5px;
        color: #cbd5e1;
        font-style: italic;
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 12px;
        font-size: 12.5px;
        color: #475569;
        line-height: 1.6;
    }

        .info-item i {
            color: #93c5fd;
            font-size: 14px;
            margin-top: 1px;
            flex-shrink: 0;
        }

        .info-item:last-child {
            margin-bottom: 0;
        }

    @@media (max-width: 900px) {
        .add-wrap {
            grid-template-columns: 1fr;
        }
    }
</style>

<a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="back-btn">
    <i class="bi bi-arrow-left"></i> Marka Listesine Dön
</a>

<div class="add-wrap">

    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="bi bi-bookmark-fill"></i></div>
            <div>
                <div class="form-card-title">Yeni Marka Ekle</div>
                <div style="font-size:11px; color:#94a3b8;">Araç markası ekleyin</div>
            </div>
        </div>
        <div class="form-card-body">
            <form asp-action="AddBrand" method="post">

                <div class="field-group">
                    <label class="field-label">Marka Adı</label>
                    <input asp-for="BrandName" class="form-control" id="inp-name"
                           placeholder="Örn: BMW, Mercedes, Toyota" />
                    <span asp-validation-for="BrandName" class="text-danger"></span>
                </div>

                <hr class="divider" />

                <div class="form-actions">
                    <a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="btn-cancel">
                        <i class="bi bi-x-lg"></i> İptal
                    </a>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="side-card">
        <div class="side-card-title">
            <i class="bi bi-eye-fill"></i> Canlı Önizleme
        </div>

        <div class="preview-brand-card">
            <div class="preview-avatar" id="prev-avatar" style="display:none;">B</div>
            <div id="prev-content">
                <span class="preview-empty">Marka adını yazmaya başlayın...</span>
            </div>
        </div>

        <div class="info-item">
            <i class="bi bi-check-circle"></i>
            Marka listesinde renkli avatar ile görünecek.
        </div>
        <div class="info-item">
            <i class="bi bi-car-front"></i>
            Bu markaya daha sonra araç ekleyebilirsiniz.
        </div>
        <div class="info-item">
            <i class="bi bi-shield-check"></i>
            Kaydet'e basınca marka listesine yönlendirilirsiniz.
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('inp-name').addEventListener('input', function () {
            var val = this.value.trim();
            var avatar = document.getElementById('prev-avatar');
            var content = document.getElementById('prev-content');

            if (val) {
                avatar.style.display = 'flex';
                avatar.textContent = val.charAt(0).toUpperCase();
                content.innerHTML = '<div class="preview-brand-name">' + val + '</div>';
            } else {
                avatar.style.display = 'none';
                content.innerHTML = '<span class="preview-empty">Marka adını yazmaya başlayın...</span>';
            }
        });
    </script>
}