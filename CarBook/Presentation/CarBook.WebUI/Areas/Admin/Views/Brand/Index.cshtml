@model List<ResultBrandDto>
@{
    ViewData["Title"] = "Marka Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddBrand", "Brand", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .brand-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 14px;
    }

    .brand-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow .2s, border-color .2s, transform .2s;
        position: relative;
        overflow: hidden;
    }

        .brand-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #3b82f6, #6366f1);
            opacity: 0;
            transition: opacity .2s ease;
        }

        .brand-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

            .brand-card:hover::before {
                opacity: 1;
            }

    .brand-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
        letter-spacing: -1px;
    }

    .brand-info {
        flex: 1;
        min-width: 0;
    }

    .brand-name {
        font-size: 14.5px;
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 3px;
    }

    .brand-meta {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .brand-id-badge {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: 1px 8px;
        font-size: 10.5px;
        font-weight: 600;
        font-family: monospace;
    }

    .brand-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #475569;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #2563eb;
            text-decoration: none;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            text-decoration: none;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

@{
    // Her marka için farklı renk — ilk harfe göre
    var colors = new[] {
        "#3b82f6", "#6366f1", "#8b5cf6", "#ec4899",
        "#f59e0b", "#10b981", "#ef4444", "#14b8a6",
        "#f97316", "#06b6d4", "#84cc16", "#a855f7"
    };

    int colorIndex = 0;
}

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) marka</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="brand-grid">
        @foreach (var item in Model)
        {
            var color = colors[colorIndex % colors.Length];
            colorIndex++;

            <div class="brand-card">
                <div class="brand-avatar" style="background: @color;">
                    @item.BrandName?.Substring(0, 1).ToUpper()
                </div>
                <div class="brand-info">
                    <div class="brand-name">@item.BrandName</div>
                    <div class="brand-meta">
                        <span class="brand-id-badge">#@item.BrandId</span>
                    </div>
                </div>
                <div class="brand-actions">
                    <a asp-area="Admin" asp-controller="Brand" asp-action="UpdateBrand"
                       asp-route-id="@item.BrandId" class="btn-edit" title="Düzenle">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-area="Admin" asp-controller="Brand" asp-action="DeleteBrand"
                       asp-route-id="@item.BrandId" class="btn-delete" title="Sil">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-bookmark" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz marka eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk markayı ekleyin.</div>
        <a asp-area="Admin" asp-controller="Brand" asp-action="AddBrand"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Marka Ekle
        </a>
    </div>
}