@model List<ResultLocationDto>
@{
    ViewData["Title"] = "Lokasyon Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddLocation", "Location", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .loc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }

    .loc-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: box-shadow .2s, border-color .2s;
    }

        .loc-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .loc-icon {
        width: 46px;
        height: 46px;
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .loc-icon i {
            font-size: 20px;
            color: #16a34a;
        }

    .loc-name {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
        flex: 1;
    }

    .loc-id {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 11px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 11px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) lokasyon</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="loc-grid">
        @foreach (var item in Model)
        {
            <div class="loc-card">
                <div class="loc-icon">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
                <div style="flex:1; min-width:0;">
                    <div class="loc-name">@item.Name</div>
                    <div class="loc-id">#@item.LocationId</div>
                </div>
                <div style="display:flex; gap:6px; flex-shrink:0;">
                    <a asp-area="Admin" asp-controller="Location" asp-action="UpdateLocation" asp-route-id="@item.LocationId" class="btn-edit">
                        <i class="bi bi-pencil" style="font-size:10px;"></i> Düzenle
                    </a>
                    <a asp-area="Admin" asp-controller="Location" asp-action="DeleteLocation" asp-route-id="@item.LocationId" class="btn-delete">
                        <i class="bi bi-trash" style="font-size:10px;"></i> Sil
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-geo-alt" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz lokasyon eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk lokasyonu ekleyin.</div>
        <a asp-area="Admin" asp-controller="Location" asp-action="AddLocation" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#16a34a,#15803d); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Lokasyon Ekle
        </a>
    </div>
}
