@model List<ResultContactDto>

@{
    ViewData["Title"] = "İletişim Mesajları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .contact-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 10px;
        transition: .2s;
    }

        .contact-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .contact-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    .contact-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .contact-name {
        font-size: 13px;
        font-weight: 600;
        color: #0f172a;
    }

    .contact-email {
        font-size: 11px;
        color: #64748b;
    }

    .contact-date {
        font-size: 11px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .contact-subject {
        font-size: 13px;
        font-weight: 600;
        color: #1d4ed8;
        margin-bottom: 6px;
    }

    .contact-message {
        font-size: 13px;
        color: #374151;
        line-height: 1.6;
        background: #f8fafc;
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 10px 14px;
        margin-bottom: 10px;
    }

    .contact-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .mail-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #ecfeff;
        color: #0891b2;
        border: 1px solid #a5f3fc;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #ecfeff;
        color: #0891b2;
        border: 1px solid #a5f3fc;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) mesaj</span>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="contact-card">

            <div class="contact-header">
                <div class="contact-avatar">
                    @item.Name?.Substring(0, 1).ToUpper()
                </div>

                <div style="flex:1;">
                    <div class="contact-name">@item.Name</div>
                    <div class="contact-email">@item.Email</div>
                </div>

                <div class="contact-date">
                    <i class="bi bi-clock"></i>
                    @item.SendDate.ToString("dd MMM yyyy HH:mm")
                </div>
            </div>

            <div class="contact-subject">
                @item.Subject
            </div>

            <div class="contact-message">
                @item.Message
            </div>

            <div class="contact-footer">
                <span class="mail-badge">
                    <i class="bi bi-envelope"></i>
                    Mail
                </span>

                <a asp-area="Admin"
                   asp-controller="Contact"
                   asp-action="DeleteContact"
                   asp-route-id="@item.Id"
                   class="btn-delete">
                    <i class="bi bi-trash"></i> Sil
                </a>
            </div>

        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-envelope-open" style="font-size:40px; color:#cbd5e1;"></i>
        <div style="margin-top:10px; font-weight:600;">Hiç mesaj yok</div>
        <div style="font-size:13px; color:#94a3b8;">İletişim mesajları burada görünecek</div>
    </div>
}