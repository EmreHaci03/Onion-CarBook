@model UpdateTestimonialDto
@{
    ViewData["Title"] = "Yorum Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 20px;
        height: calc(100vh - 120px);
    }

    .left-panel {
        background: linear-gradient(145deg, #1a0a2e, #2d1b4e);
        border-radius: 16px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            background: rgba(245,158,11,.12);
            border-radius: 50%;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            background: rgba(239,68,68,.1);
            border-radius: 50%;
        }

    .left-top {
        position: relative;
        z-index: 1;
    }

    .left-icon {
        width: 52px;
        height: 52px;
        background: rgba(245,158,11,.2);
        border: 1px solid rgba(245,158,11,.3);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

        .left-icon i {
            font-size: 24px;
            color: #fbbf24;
        }

    .left-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 10px;
    }

    .left-desc {
        font-size: 13px;
        color: #94a3b8;
        line-height: 1.6;
    }

    .preview-box {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 12px;
        padding: 16px;
        position: relative;
        z-index: 1;
    }

    .preview-label {
        font-size: 10px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .preview-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .preview-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        flex-shrink: 0;
        overflow: hidden;
    }

        .preview-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .preview-name {
        font-size: 13px;
        font-weight: 700;
        color: #f1f5f9;
    }

    .preview-ptitle {
        font-size: 11px;
        color: #64748b;
    }

    .preview-comment {
        font-size: 11px;
        color: #94a3b8;
        line-height: 1.6;
        border-left: 2px solid #f59e0b;
        padding-left: 10px;
    }

    .right-panel {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .right-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .right-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .right-subtitle {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .right-body {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
    }

    .field-group {
        margin-bottom: 18px;
    }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-label i {
            font-size: 13px;
            color: #94a3b8;
        }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 13px;
        color: #0f172a;
        font-family: 'Segoe UI', sans-serif;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        background: #fafafa;
        box-sizing: border-box;
    }

        .form-control:focus {
            border-color: #fcd34d;
            box-shadow: 0 0 0 3px rgba(245,158,11,.1);
            background: #fff;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .text-danger {
        font-size: 11px;
        color: #dc2626;
        display: block;
        margin-top: 3px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .right-footer {
        padding: 16px 24px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
    }

    .footer-note {
        font-size: 11px;
        color: #94a3b8;
    }

    .form-actions {
        display: flex;
        gap: 8px;
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #374151;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #fff;
        cursor: pointer;
        transition: opacity .15s;
    }

        .btn-save:hover {
            opacity: .9;
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        margin-bottom: 16px;
        transition: color .15s;
    }

        .back-btn:hover {
            color: #374151;
        }

    .edit-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        color: #92400e;
        font-weight: 500;
    }
</style>

<a asp-area="Admin" asp-controller="Testimonial" asp-action="Index" class="back-btn">
    <i class="bi bi-arrow-left"></i> Yorum Listesine Dön
</a>

<div class="page-grid">
    <div class="left-panel">
        <div class="left-top">
            <div class="left-icon"><i class="bi bi-pencil-square"></i></div>
            <div class="left-title">Yorum Düzenleme</div>
            <div class="left-desc">Yorum bilgilerini güncelleyin.</div>
        </div>
        <div style="position:relative; z-index:1;">
            <div class="preview-box">
                <div class="preview-label">Canlı Önizleme</div>
                <div class="preview-header">
                    <div class="preview-avatar">
                        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                        {
                            <img id="prev-img" src="@Model.ImageUrl" alt="" />
                        }
                        else
                        {
                            <span id="prev-initial">@Model?.Name?.Substring(0, 1).ToUpper()</span>
                            <img id="prev-img" src="" alt="" style="display:none;" />
                        }
                    </div>
                    <div>
                        <div class="preview-name" id="prev-name">@Model?.Name</div>
                        <div class="preview-ptitle" id="prev-title">@Model?.Title</div>
                    </div>
                </div>
                <div class="preview-comment" id="prev-comment">@Model?.Comment</div>
            </div>
        </div>
    </div>

    <div class="right-panel">
        <div class="right-header">
            <div>
                <div class="right-title">Yorum Güncelle</div>
                <div class="right-subtitle">Değiştirmek istediğiniz alanları düzenleyin</div>
            </div>
            <span class="edit-badge"><i class="bi bi-pencil-fill"></i> Düzenleme Modu</span>
        </div>
        <div class="right-body">
            <form asp-action="UpdateTestimonial" method="post" id="testimonialForm">
                <input asp-for="Id" type="hidden" />
                <div class="form-row">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-person"></i> Ad Soyad</label>
                        <input asp-for="Name" class="form-control" id="inp-name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-briefcase"></i> Unvan</label>
                        <input asp-for="Title" class="form-control" id="inp-title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label"><i class="bi bi-image"></i> Profil Görseli URL</label>
                    <input asp-for="ImageUrl" class="form-control" id="inp-img" />
                </div>
                <div class="field-group">
                    <label class="field-label"><i class="bi bi-chat-text"></i> Yorum</label>
                    <textarea asp-for="Comment" class="form-control" id="inp-comment"></textarea>
                    <span asp-validation-for="Comment" class="text-danger"></span>
                </div>
            </form>
        </div>
        <div class="right-footer">
            <div class="footer-note"><i class="bi bi-clock-history me-1"></i>Değişiklikler anında yayınlanır.</div>
            <div class="form-actions">
                <a asp-area="Admin" asp-controller="Testimonial" asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> İptal
                </a>
                <button type="submit" form="testimonialForm" class="btn-save">
                    <i class="bi bi-check-lg"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('inp-name').addEventListener('input', function() {
        document.getElementById('prev-name').textContent = this.value;
    });
    document.getElementById('inp-title').addEventListener('input', function() {
        document.getElementById('prev-title').textContent = this.value;
    });
    document.getElementById('inp-comment').addEventListener('input', function() {
        document.getElementById('prev-comment').textContent = this.value;
    });
    document.getElementById('inp-img').addEventListener('input', function() {
        var img = document.getElementById('prev-img');
        var initial = document.getElementById('prev-initial');
        if (this.value) { img.src = this.value; img.style.display = 'block'; if (initial) initial.style.display = 'none'; }
        else { img.style.display = 'none'; if (initial) initial.style.display = 'block'; }
    });
</script>
