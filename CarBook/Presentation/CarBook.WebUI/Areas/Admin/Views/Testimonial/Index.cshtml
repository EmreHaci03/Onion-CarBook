@model List<ResultTestimonialDto>
@{
    ViewData["Title"] = "Yorum Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddTestimonial", "Testimonial", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .testimonial-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 14px;
    }

    .testimonial-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px;
        transition: box-shadow .2s, border-color .2s;
    }

        .testimonial-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .testimonial-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .testimonial-avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e2e8f0;
        flex-shrink: 0;
    }

    .testimonial-avatar-placeholder {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .testimonial-name {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .testimonial-title {
        font-size: 11px;
        color: #64748b;
        margin-top: 2px;
    }

    .testimonial-quote {
        font-size: 12px;
        color: #374151;
        line-height: 1.7;
        background: #f8fafc;
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 10px 12px;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .testimonial-actions {
        display: flex;
        gap: 8px;
    }

    .btn-edit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    .btn-delete {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .quote-icon {
        font-size: 20px;
        color: #bfdbfe;
        margin-bottom: 4px;
        display: block;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) yorum</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="testimonial-grid">
        @foreach (var item in Model)
        {
            <div class="testimonial-card">
                <div class="testimonial-header">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" class="testimonial-avatar" />
                    }
                    else
                    {
                        <div class="testimonial-avatar-placeholder">@item.Name?.Substring(0, 1).ToUpper()</div>
                    }
                    <div>
                        <div class="testimonial-name">@item.Name</div>
                        <div class="testimonial-title">@item.Title</div>
                    </div>
                </div>
                <i class="bi bi-quote quote-icon"></i>
                <div class="testimonial-quote">@item.Comment</div>
                <div class="testimonial-actions">
                    <a asp-area="Admin" asp-controller="Testimonial" asp-action="UpdateTestimonial" asp-route-id="@item.Id" class="btn-edit">
                        <i class="bi bi-pencil" style="font-size:11px;"></i> Düzenle
                    </a>
                    <a asp-area="Admin" asp-controller="Testimonial" asp-action="DeleteTestimonial" asp-route-id="@item.Id" class="btn-delete">
                        <i class="bi bi-trash" style="font-size:11px;"></i> Sil
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-chat-quote" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz yorum eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk yorumu ekleyin.</div>
        <a asp-area="Admin" asp-controller="Testimonial" asp-action="AddTestimonial" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Yorum Ekle
        </a>
    </div>
}
