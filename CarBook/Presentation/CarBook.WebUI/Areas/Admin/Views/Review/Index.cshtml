@{
    ViewData["Title"] = "Yorum Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .rv-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 16px;
    }

    .rv-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s, transform .2s;
    }

        .rv-card:hover {
            box-shadow: 0 8px 30px rgba(0,0,0,.08);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

    .rv-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .rv-user {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .rv-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #dbeafe;
        color: #1d4ed8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .rv-name {
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
    }

    .rv-meta {
        font-size: 10px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .rv-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 2px 9px;
        font-size: 10px;
        font-weight: 700;
    }

    .rv-avg-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        background: #fefce8;
        color: #a16207;
        border: 1px solid #fef08a;
        border-radius: 20px;
        padding: 2px 9px;
        font-size: 10px;
        font-weight: 700;
        margin-top: 4px;
    }

    .rv-card-body {
        padding: 14px 16px;
    }

    .rv-comment {
        font-size: 12.5px;
        color: #475569;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 12px;
    }

    .rv-ratings {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 7px;
    }

    .rv-rating-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #f8fafc;
        border-radius: 8px;
        padding: 6px 10px;
    }

    .rv-rating-lbl {
        font-size: 10.5px;
        color: #64748b;
    }

    .rv-stars {
        display: flex;
        gap: 1px;
    }

        .rv-stars i {
            font-size: 10px;
            color: #f59e0b;
        }

            .rv-stars i.empty {
                color: #e2e8f0;
            }

    .rv-card-footer {
        display: flex;
        gap: 8px;
        padding: 10px 16px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-edit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #1d4ed8;
            text-decoration: none;
        }

    .btn-delete {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .search-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px 16px;
    }

        .search-bar i {
            color: #94a3b8;
            font-size: 16px;
        }

    .search-input {
        border: none;
        outline: none;
        font-size: 13px;
        color: #0f172a;
        flex: 1;
        background: transparent;
    }

        .search-input::placeholder {
            color: #cbd5e1;
        }

    .id-input-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 6px 12px;
    }

        .id-input-wrap input {
            border: none;
            outline: none;
            font-size: 13px;
            color: #0f172a;
            width: 90px;
            background: transparent;
        }

            .id-input-wrap input::placeholder {
                color: #cbd5e1;
            }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 16px;
        background: #3b82f6;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }

        .btn-search:hover {
            background: #2563eb;
        }

    .btn-reset {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 12px;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-reset:hover {
            background: #e2e8f0;
        }

    .filter-chips {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 500;
    }

        .filter-chip button {
            background: none;
            border: none;
            cursor: pointer;
            color: #3b82f6;
            font-size: 12px;
            padding: 0;
            line-height: 1;
            margin-left: 2px;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 60px 20px;
        text-align: center;
    }

    .loading-box {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
        font-size: 14px;
    }

    /* Delete Modal */
    .del-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .del-overlay.active {
            display: flex;
        }

    .del-box {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        width: 90%;
        max-width: 390px;
        box-shadow: 0 24px 64px rgba(0,0,0,.22);
    }

    .del-top {
        background: #fff5f5;
        padding: 26px 24px 20px;
        text-align: center;
        border-bottom: 1px solid #fee2e2;
    }

    .del-icon {
        width: 52px;
        height: 52px;
        background: #fee2e2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 22px;
        color: #dc2626;
    }

    .del-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .del-reviewer {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
        color: #dc2626;
        margin-top: 8px;
    }

    .del-body {
        padding: 18px 24px 22px;
    }

    .del-preview {
        font-size: 12.5px;
        color: #64748b;
        background: #f8fafc;
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #e2e8f0;
        margin-bottom: 18px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .del-actions {
        display: flex;
        gap: 10px;
    }

    .btn-del-cancel {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-del-cancel:hover {
            background: #e2e8f0;
        }

    .btn-del-confirm {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px;
        background: #dc2626;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        text-decoration: none;
        transition: background .15s;
    }

        .btn-del-confirm:hover {
            background: #b91c1c;
            text-decoration: none;
        }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<!-- Toolbar -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge" id="count-badge">— yorum</span>
    </div>
</div>

<!-- Arama -->
<div class="search-bar">
    <i class="bi bi-search"></i>
    <input type="text" class="search-input" id="search-text" placeholder="İsim veya yorum içeriği ile ara..." oninput="filterCards()" />
    <div class="id-input-wrap">
        <i class="bi bi-car-front" style="color:#94a3b8; font-size:13px;"></i>
        <input type="number" id="search-car-id" placeholder="Araç ID" min="1" />
    </div>
    <button class="btn-search" onclick="searchByCarId()">
        <i class="bi bi-search" style="font-size:11px;"></i> Araç ID
    </button>
    <button class="btn-reset" onclick="resetSearch()">
        <i class="bi bi-x-lg" style="font-size:11px;"></i> Sıfırla
    </button>
</div>

<!-- Aktif Filtre -->
<div class="filter-chips" id="filter-chips" style="display:none;">
    <span style="font-size:12px; color:#64748b;">Filtre:</span>
    <div class="filter-chip">
        <i class="bi bi-funnel-fill" style="font-size:10px;"></i>
        <span id="active-filter-text"></span>
        <button onclick="resetSearch()"><i class="bi bi-x"></i></button>
    </div>
</div>

<!-- Liste -->
<div id="rv-container">
    <div class="loading-box">
        <i class="bi bi-arrow-repeat" style="font-size:28px; display:block; margin-bottom:10px; animation: spin 1s linear infinite;"></i>
        Yorumlar yükleniyor...
    </div>
</div>

<!-- Delete Modal -->
<div class="del-overlay" id="del-modal">
    <div class="del-box">
        <div class="del-top">
            <div class="del-icon"><i class="bi bi-trash3-fill"></i></div>
            <div class="del-title">Yorumu silmek istiyor musunuz?</div>
            <div class="del-reviewer">
                <i class="bi bi-person-fill" style="font-size:10px;"></i>
                <span id="del-name-text"></span>
            </div>
        </div>
        <div class="del-body">
            <div class="del-preview" id="del-comment-preview"></div>
            <div class="del-actions">
                <button class="btn-del-cancel" onclick="closeDelModal()">
                    <i class="bi bi-x-lg" style="font-size:12px;"></i> Vazgeç
                </button>
                <a href="#" id="del-confirm-btn" class="btn-del-confirm">
                    <i class="bi bi-trash3-fill" style="font-size:12px;"></i> Evet, Sil
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    let allData = [];

    function getInitials(name) {
        if (!name) return '?';
        const parts = name.trim().split(' ');
        return parts.length >= 2
            ? (parts[0][0] + parts[1][0]).toUpperCase()
            : parts[0].slice(0, 2).toUpperCase();
    }

    function getStars(rating) {
        let html = '';
        for (let i = 1; i <= 5; i++) {
            html += i <= rating
                ? '<i class="bi bi-star-fill"></i>'
                : '<i class="bi bi-star empty"></i>';
        }
        return html;
    }

    function avgRating(x) {
        return ((x.cleanlinessRating + x.comfortRating + x.priceRating + x.deliveryRating) / 4).toFixed(1);
    }

    async function loadAll() {
        try {
            const res = await fetch('https://localhost:7211/api/Review');
            allData = await res.json();
            document.getElementById('count-badge').textContent = allData.length + ' yorum';
            renderCards(allData);
        } catch (e) {
            document.getElementById('rv-container').innerHTML = '<div class="empty-box"><i class="bi bi-exclamation-circle" style="font-size:36px; color:#fca5a5; display:block; margin-bottom:10px;"></i><div style="font-size:14px; color:#374151;">Veriler yüklenirken hata oluştu.</div></div>';
        }
    }

    async function searchByCarId() {
        const id = document.getElementById('search-car-id').value;
        if (!id) { resetSearch(); return; }
        document.getElementById('rv-container').innerHTML = '<div class="loading-box"><i class="bi bi-arrow-repeat" style="font-size:28px; display:block; margin-bottom:10px;"></i> Aranıyor...</div>';
        try {
            const res = await fetch('https://localhost:7211/api/Review/GetReviewsByCarId/' + id);
            if (!res.ok) throw new Error();
            const data = await res.json();
            document.getElementById('filter-chips').style.display = 'flex';
            document.getElementById('active-filter-text').textContent = 'Araç ID: ' + id;
            document.getElementById('count-badge').textContent = data.length + ' yorum';
            document.getElementById('search-text').value = '';
            renderCards(data);
        } catch (e) {
            document.getElementById('rv-container').innerHTML = '<div class="empty-box"><i class="bi bi-search" style="font-size:36px; color:#cbd5e1; display:block; margin-bottom:10px;"></i><div style="font-size:14px; color:#374151; margin-bottom:6px;">Sonuç bulunamadı</div><div style="font-size:12px; color:#94a3b8;">Araç ID: ' + id + ' için yorum yok</div></div>';
        }
    }

    function filterCards() {
        const q = document.getElementById('search-text').value.toLowerCase();
        if (!q) {
            renderCards(allData);
            document.getElementById('count-badge').textContent = allData.length + ' yorum';
            document.getElementById('filter-chips').style.display = 'none';
            return;
        }
        const filtered = allData.filter(x =>
            (x.reviewerName && x.reviewerName.toLowerCase().includes(q)) ||
            (x.comment && x.comment.toLowerCase().includes(q))
        );
        document.getElementById('filter-chips').style.display = 'flex';
        document.getElementById('active-filter-text').textContent = '"' + q + '" araması';
        document.getElementById('count-badge').textContent = filtered.length + ' yorum';
        renderCards(filtered);
    }

    function resetSearch() {
        document.getElementById('search-text').value = '';
        document.getElementById('search-car-id').value = '';
        document.getElementById('filter-chips').style.display = 'none';
        document.getElementById('count-badge').textContent = allData.length + ' yorum';
        renderCards(allData);
    }

    function renderCards(data) {
        if (!data || data.length === 0) {
            document.getElementById('rv-container').innerHTML = '<div class="empty-box"><i class="bi bi-chat-square-text" style="font-size:42px; color:#cbd5e1; display:block; margin-bottom:14px;"></i><div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Yorum bulunamadı</div><div style="font-size:13px; color:#94a3b8;">Farklı bir arama deneyin.</div></div>';
            return;
        }

        let html = '<div class="rv-grid">';
        data.forEach(function (item) {
            const initials = getInitials(item.reviewerName);
            const avg = avgRating(item);
            const date = item.createdDate ? new Date(item.createdDate).toLocaleDateString('tr-TR') : '—';
            const comment = item.comment || '—';

            html += `
                <div class="rv-card">
                    <div class="rv-card-head">
                        <div class="rv-user">
                            <div class="rv-avatar">${initials}</div>
                            <div>
                                <div class="rv-name">${item.reviewerName || '—'}</div>
                                <div class="rv-meta">${date} · Araç ID: ${item.carId}</div>
                            </div>
                        </div>
                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                            <span class="rv-id-badge"><i class="bi bi-hash" style="font-size:9px;"></i>${item.id}</span>
                            <span class="rv-avg-badge"><i class="bi bi-star-fill" style="font-size:9px;"></i> ${avg}</span>
                        </div>
                    </div>
                    <div class="rv-card-body">
                        <div class="rv-comment">${comment}</div>
                        <div class="rv-ratings">
                            <div class="rv-rating-item">
                                <span class="rv-rating-lbl">Temizlik</span>
                                <div class="rv-stars">${getStars(item.cleanlinessRating)}</div>
                            </div>
                            <div class="rv-rating-item">
                                <span class="rv-rating-lbl">Konfor</span>
                                <div class="rv-stars">${getStars(item.comfortRating)}</div>
                            </div>
                            <div class="rv-rating-item">
                                <span class="rv-rating-lbl">Fiyat/Kalite</span>
                                <div class="rv-stars">${getStars(item.priceRating)}</div>
                            </div>
                            <div class="rv-rating-item">
                                <span class="rv-rating-lbl">Teslim</span>
                                <div class="rv-stars">${getStars(item.deliveryRating)}</div>
                            </div>
                        </div>
                    </div>
                    <div class="rv-card-footer">
                        <button class="btn-delete" onclick="openDelModal(${item.id}, '${item.reviewerName}', \`${comment.replace(/`/g, "'")}\`)">
                            <i class="bi bi-trash-fill" style="font-size:10px;"></i> Sil
                        </button>
                    </div>
                </div>`;
        });
        html += '</div>';
        document.getElementById('rv-container').innerHTML = html;
    }

    function openDelModal(id, name, comment) {
        document.getElementById('del-name-text').textContent = name;
        document.getElementById('del-comment-preview').textContent = comment;
        document.getElementById('del-confirm-btn').href = '/Admin/Review/DeleteReview?id=' + id;
        document.getElementById('del-modal').classList.add('active');
    }

    function closeDelModal() {
        document.getElementById('del-modal').classList.remove('active');
    }

    document.getElementById('del-modal').addEventListener('click', function (e) {
        if (e.target === this) closeDelModal();
    });

    loadAll();
</script>
