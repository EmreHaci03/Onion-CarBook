@model List<ResultBlogDto>
@{
    ViewData["Title"] = "Blog Yönetimi";
    ViewData["AddUrl"] = Url.Action("AdminAddBlog", "Blog", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .blog-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s;
        margin-bottom: 12px;
        display: flex;
    }

        .blog-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .blog-img {
        width: 140px;
        height: 110px;
        object-fit: cover;
        flex-shrink: 0;
        background: #f1f5f9;
    }

    .blog-img-placeholder {
        width: 140px;
        height: 110px;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .blog-body {
        flex: 1;
        padding: 14px 18px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-width: 0;
    }

    .blog-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 6px;
    }

    .badge-category {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10px;
        font-weight: 600;
    }

    .badge-date {
        font-size: 11px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .badge-author {
        font-size: 11px;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .blog-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .blog-desc {
        font-size: 12px;
        color: #64748b;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .blog-actions {
        display: flex;
        gap: 8px;
        margin-top: 8px;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .author-avatar {
        width: 18px;
        height: 18px;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        flex-shrink: 0;
    }
</style>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge">@(Model?.Count ?? 0) blog</span>
    </div>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="blog-card">
            @if (!string.IsNullOrEmpty(item.CoverImageUrl))
            {
                <img src="@item.CoverImageUrl" alt="@item.Title" class="blog-img" />
            }
            else
            {
                <div class="blog-img-placeholder">
                    <i class="bi bi-file-text" style="font-size:28px; color:#93c5fd;"></i>
                </div>
            }
            <div class="blog-body">
                <div>
                    <div class="blog-meta">
                        <span class="badge-category">@item.BlogCategoryName</span>
                        <span class="badge-date"><i class="bi bi-calendar3" style="font-size:10px;"></i> @item.CreateDate.ToString("dd MMM yyyy")</span>
                        <span class="badge-author">
                            <span class="author-avatar">@(item.AuthorName?.Substring(0,1).ToUpper())</span>
                            @item.AuthorName
                        </span>
                    </div>
                    <div class="blog-title">@item.Title</div>
                    <div class="blog-desc">@item.Description</div>
                </div>
                <div class="blog-actions">
                    <a asp-area="Admin" asp-controller="Comment" asp-action="GetCommentByBlogId" asp-route-id="@item.Id" style="display:inline-flex; align-items:center; gap:5px; padding:5px 12px; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:7px; font-size:11px; font-weight:500; color:#15803d; text-decoration:none;">
                        <i class="bi bi-chat-dots" style="font-size:11px;"></i> Yorumlar
                    </a>
                    <a asp-area="Admin" asp-controller="Blog" asp-action="AdminUpdateBlog" asp-route-id="@item.Id" class="btn-edit">
                        <i class="bi bi-pencil" style="font-size:11px;"></i> Düzenle
                    </a>
                    <a asp-area="Admin" asp-controller="Blog" asp-action="AdminDeleteBlog" asp-route-id="@item.Id" class="btn-delete">
                        <i class="bi bi-trash" style="font-size:11px;"></i> Sil
                    </a>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-file-text" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz blog yazısı eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk blog yazınızı ekleyin.</div>
        <a asp-area="Admin" asp-controller="Blog" asp-action="AdminAddBlog" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Blog Ekle
        </a>
    </div>
}
