@model List<ResultBlogCategoryDto>
@{
    ViewData["Title"] = "Blog Kategorileri";
    ViewData["AddUrl"] = Url.Action("AddBlogCategory", "BlogCategory", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .cat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 14px;
    }

    .cat-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow .2s, border-color .2s, transform .2s;
        position: relative;
        overflow: hidden;
    }

        .cat-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #3b82f6, #6366f1);
            opacity: 0;
            transition: opacity .2s ease;
        }

        .cat-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

            .cat-card:hover::before {
                opacity: 1;
            }

    .cat-icon {
        width: 46px;
        height: 46px;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .cat-icon i {
            font-size: 20px;
            color: #3b82f6;
        }

    .cat-info {
        flex: 1;
        min-width: 0;
    }

    .cat-name {
        font-size: 14.5px;
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 3px;
    }

    .cat-id-badge {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: 1px 8px;
        font-size: 10.5px;
        font-weight: 600;
        font-family: monospace;
        display: inline-block;
    }

    .cat-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #475569;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #2563eb;
            text-decoration: none;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
        font-size: 13px;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            text-decoration: none;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) kategori</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="cat-grid">
        @foreach (var item in Model)
        {
            <div class="cat-card">
                <div class="cat-icon">
                    <i class="bi bi-tag-fill"></i>
                </div>
                <div class="cat-info">
                    <div class="cat-name">@item.Name</div>
                    <span class="cat-id-badge">#@item.Id</span>
                </div>
                <div class="cat-actions">
                    <a asp-area="Admin" asp-controller="BlogCategory" asp-action="UpdateBlogCategory"
                       asp-route-id="@item.Id" class="btn-edit" title="Düzenle">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-area="Admin" asp-controller="BlogCategory" asp-action="DeleteBlogCategory"
                       asp-route-id="@item.Id" class="btn-delete" title="Sil">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-tags" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz kategori eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk kategoriyi ekleyin.</div>
        <a asp-area="Admin" asp-controller="BlogCategory" asp-action="AddBlogCategory"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Kategori Ekle
        </a>
    </div>
}
