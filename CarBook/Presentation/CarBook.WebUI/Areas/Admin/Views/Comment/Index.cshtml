@model List<ResultCommentDto>
@{
    ViewData["Title"] = "Yorum Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .comment-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 10px;
        transition: box-shadow .2s, border-color .2s;
    }

        .comment-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .comment-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    .comment-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .comment-name {
        font-size: 13px;
        font-weight: 600;
        color: #0f172a;
    }

    .comment-date {
        font-size: 11px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .comment-body {
        font-size: 13px;
        color: #374151;
        line-height: 1.7;
        background: #f8fafc;
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 10px 14px;
        margin-bottom: 10px;
    }

    .comment-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .blog-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        margin-bottom: 16px;
        transition: color .15s;
    }

        .back-btn:hover {
            color: #374151;
        }
</style>

<a asp-area="Admin" asp-controller="Blog" asp-action="Index" class="back-btn">
    <i class="bi bi-arrow-left"></i> Blog Listesine Dön
</a>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) yorum</span>
    @if (Model != null && Model.Any() && !string.IsNullOrEmpty(Model.First().BlogName))
    {
        <span style="font-size:13px; color:#64748b;">—</span>
        <span style="font-size:13px; font-weight:600; color:#0f172a;">@Model.First().BlogName</span>
    }
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="comment-card">
            <div class="comment-header">
                <div class="comment-avatar">@item.Name?.Substring(0, 1).ToUpper()</div>
                <div style="flex:1;">
                    <div class="comment-name">@item.Name</div>
                    @if (!string.IsNullOrEmpty(item.Email))
                    {
                        <div style="font-size:11px; color:#3b82f6; display:flex; align-items:center; gap:4px; margin-top:1px;">
                            <i class="bi bi-envelope" style="font-size:10px;"></i>
                            @(!string.IsNullOrEmpty(item.Email) ? @item.Email : "")
                        </div>
                    }
                    <div class="comment-date">
                        <i class="bi bi-clock" style="font-size:10px;"></i>
                        @item.CreatedDate.ToString("dd MMM yyyy HH:mm")
                    </div>
                </div>
            </div>
            <div class="comment-body">@item.Content</div>
            <div class="comment-footer">
                <span class="blog-badge">
                    <i class="bi bi-file-text" style="font-size:10px;"></i>
                    @(string.IsNullOrEmpty(item.BlogName) ? $"Blog #{item.BlogId}" : item.BlogName)
                </span>
                <a asp-area="Admin" asp-controller="Comment" asp-action="DeleteComment" asp-route-id="@item.CommentId" class="btn-delete">
                    <i class="bi bi-trash" style="font-size:11px;"></i> Sil
                </a>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-chat" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Bu blog için henüz yorum yapılmamış</div>
        <div style="font-size:13px; color:#94a3b8;">Yorumlar burada listelenecek.</div>
    </div>
}
