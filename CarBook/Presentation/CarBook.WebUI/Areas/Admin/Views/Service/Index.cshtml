@model List<ResultServiceDto>
@{
    ViewData["Title"] = "Hizmet Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddService", "Service", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .service-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow .2s, border-color .2s, transform .2s;
        margin-bottom: 12px;
        position: relative;
        overflow: hidden;
    }

        .service-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #8b5cf6, #6366f1);
            opacity: 0;
            transition: opacity .2s ease;
        }

        .service-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
            border-color: #ddd6fe;
            transform: translateY(-2px);
        }

            .service-card:hover::before {
                opacity: 1;
            }

    .service-icon-wrap {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, #f5f3ff, #ede9fe);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 24px;
        color: #7c3aed;
    }

    .service-info {
        flex: 1;
        min-width: 0;
    }

    .service-title {
        font-size: 14.5px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .service-desc {
        font-size: 12px;
        color: #64748b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 6px;
    }

    .icon-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #f5f3ff;
        color: #6d28d9;
        border: 1px solid #ddd6fe;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10.5px;
        font-weight: 600;
        font-family: monospace;
    }

    .service-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #475569;
        text-decoration: none;
        transition: all .15s;
        font-size: 14px;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #2563eb;
            text-decoration: none;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
        font-size: 14px;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            text-decoration: none;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #f5f3ff;
        color: #6d28d9;
        border: 1px solid #ddd6fe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) hizmet</span>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="service-card">
            <div class="service-icon-wrap">
                <span class="@item.Icon"></span>
            </div>
            <div class="service-info">
                <div class="service-title">@item.Title</div>
                <div class="service-desc">@item.Description</div>
                <span class="icon-badge"><i class="bi bi-box" style="font-size:10px;"></i> @item.Icon</span>
            </div>
            <div class="service-actions">
                <a asp-area="Admin" asp-controller="Service" asp-action="UpdateService" asp-route-id="@item.Id" class="btn-edit" title="Düzenle">
                    <i class="bi bi-pencil"></i>
                </a>
                <a asp-area="Admin" asp-controller="Service" asp-action="DeleteService" asp-route-id="@item.Id" class="btn-delete" title="Sil">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-stars" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz hizmet eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk hizmetinizi ekleyin.</div>
        <a asp-area="Admin" asp-controller="Service" asp-action="AddService"
           style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#8b5cf6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Hizmet Ekle
        </a>
    </div>
}
