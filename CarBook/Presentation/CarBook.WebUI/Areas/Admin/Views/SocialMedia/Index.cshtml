@model List<ResultSocialMediaDto>
@{
    ViewData["Title"] = "Sosyal Medya Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddSocialMedia", "SocialMedia", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .sm-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow .2s, border-color .2s;
        margin-bottom: 10px;
    }

        .sm-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .sm-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 22px;
    }

    .sm-github {
        background: #f1f5f9;
        color: #0f172a;
    }

    .sm-instagram {
        background: #fdf2f8;
        color: #db2777;
    }

    .sm-youtube {
        background: #fef2f2;
        color: #dc2626;
    }

    .sm-twitter {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .sm-facebook {
        background: #eff6ff;
        color: #2563eb;
    }

    .sm-linkedin {
        background: #eff6ff;
        color: #0369a1;
    }

    .sm-default {
        background: #f1f5f9;
        color: #64748b;
    }

    .sm-name {
        font-size: 15px;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 3px;
    }

    .sm-url {
        font-size: 12px;
        color: #64748b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 380px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .sm-icon-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 2px 8px;
        font-size: 11px;
        color: #64748b;
        margin-top: 4px;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 14px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
            color: #0f172a;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 14px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge">@(Model?.Count ?? 0) hesap</span>
    </div>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        var iconClass = item.Icon?.ToLower() switch
        {
            var i when i != null && i.Contains("github") => "sm-github",
            var i when i != null && i.Contains("instagram") => "sm-instagram",
            var i when i != null && i.Contains("youtube") => "sm-youtube",
            var i when i != null && i.Contains("twitter") => "sm-twitter",
            var i when i != null && i.Contains("facebook") => "sm-facebook",
            var i when i != null && i.Contains("linkedin") => "sm-linkedin",
            _ => "sm-default"
        };

        <div class="sm-card">
            <div class="sm-icon @iconClass">
                <i class="@item.Icon"></i>
            </div>
            <div style="flex:1; min-width:0;">
                <div class="sm-name">@item.Name</div>
                <div class="sm-url">
                    <i class="bi bi-link-45deg" style="font-size:12px; flex-shrink:0;"></i>
                    <a href="@item.Url" target="_blank" style="color:#64748b; text-decoration:none; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@item.Url</a>
                </div>
                <div class="sm-icon-badge"><i class="bi bi-code" style="font-size:10px;"></i> @item.Icon</div>
            </div>
            <div style="display:flex; gap:8px; flex-shrink:0;">
                <a asp-area="Admin" asp-controller="SocialMedia" asp-action="UpdateSocialMedia" asp-route-id="@item.Id" class="btn-edit">
                    <i class="bi bi-pencil" style="font-size:12px;"></i> Düzenle
                </a>
                <a asp-area="Admin" asp-controller="SocialMedia" asp-action="DeleteSocialMedia" asp-route-id="@item.Id" class="btn-delete">
                    <i class="bi bi-trash" style="font-size:12px;"></i> Sil
                </a>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-share" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz sosyal medya hesabı eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk hesabı ekleyin.</div>
        <a asp-area="Admin" asp-controller="SocialMedia" asp-action="AddSocialMedia" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Hesap Ekle
        </a>
    </div>
}
