@model List<ResultCarWithBrandDto>
@{
    ViewData["Title"] = "Araç Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddCar", "Car", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .car-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 16px;
    }

    .car-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s, transform .2s;
    }

        .car-card:hover {
            box-shadow: 0 8px 30px rgba(0,0,0,.1);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

    .car-img-wrap {
        position: relative;
        overflow: hidden;
    }

    .car-img {
        width: 100%;
        height: 170px;
        object-fit: cover;
    }

    .car-img-placeholder {
        width: 100%;
        height: 170px;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .car-img-overlay {
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        gap: 6px;
    }

    .fuel-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border-radius: 20px;
        padding: 4px 10px;
        font-size: 10px;
        font-weight: 700;
        backdrop-filter: blur(8px);
    }

    .fuel-petrol {
        background: rgba(239,68,68,.85);
        color: #fff;
    }

    .fuel-diesel {
        background: rgba(59,130,246,.85);
        color: #fff;
    }

    .fuel-electric {
        background: rgba(16,185,129,.85);
        color: #fff;
    }

    .fuel-hybrid {
        background: rgba(139,92,246,.85);
        color: #fff;
    }

    .trans-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: rgba(15,23,42,.7);
        color: #fff;
        border-radius: 20px;
        padding: 4px 10px;
        font-size: 10px;
        font-weight: 600;
        backdrop-filter: blur(8px);
    }

    .car-body {
        padding: 14px 16px;
    }

    .car-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .car-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .car-brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #eff6ff;
        color: #1d4ed8;
        border-radius: 6px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 600;
        margin-top: 3px;
    }

    .car-specs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 12px;
    }

    .spec-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 11px;
        color: #374151;
        background: #f8fafc;
        border-radius: 8px;
        padding: 6px 8px;
    }

    .spec-icon {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
    }

    .spec-icon-blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .spec-icon-purple {
        background: #ede9fe;
        color: #7c3aed;
    }

    .spec-icon-green {
        background: #dcfce7;
        color: #16a34a;
    }

    .spec-icon-amber {
        background: #fef9c3;
        color: #ca8a04;
    }

    .car-actions {
        display: flex;
        gap: 8px;
        padding-top: 10px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-pricing {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 8px;
        background: #fefce8;
        border: 1px solid #fef08a;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        color: #a16207;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-pricing:hover {
            background: #fef9c3;
            border-color: #fde047;
        }

    .btn-edit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 8px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #1d4ed8;
        }

    .btn-delete {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 8px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }


        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .btn-review {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 8px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        color: #c2410c;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-review:hover {
            background: #ffedd5;
            border-color: #fb923c;
            color: #c2410c;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 16px;
        padding: 28px;
        width: 90%;
        max-width: 400px;
        position: relative;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .modal-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .modal-icon {
        width: 36px;
        height: 36px;
        background: #fefce8;
        border: 1px solid #fef08a;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-car-name {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .modal-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        padding: 0;
        line-height: 1;
    }

        .modal-close:hover {
            color: #374151;
        }

    .pricing-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        margin-bottom: 8px;
    }

    .pricing-row-name {
        font-size: 13px;
        color: #374151;
        font-weight: 500;
    }

    .pricing-row-amount {
        font-size: 13px;
        font-weight: 700;
        color: #15803d;
    }

    .pricing-empty {
        text-align: center;
        color: #94a3b8;
        font-size: 13px;
        padding: 20px 0;
    }

    .pricing-loading {
        text-align: center;
        color: #94a3b8;
        font-size: 13px;
        padding: 20px 0;
    }

    .btn-detail {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #475569;
        transition: all .15s;
    }

        .btn-detail:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: #1e293b;
            text-decoration: none;
        }

    .btn-feature {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid #ddd6fe;
        background: #f5f3ff;
        color: #6d28d9;
        transition: all .15s;
    }

        .btn-feature:hover {
            background: #ede9fe;
            border-color: #c4b5fd;
            color: #5b21b6;
            text-decoration: none;
        }
</style>

<div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
    <div style="font-size:13px; color:#64748b;">Toplam</div>
    <span class="count-badge">@(Model?.Count ?? 0) araç</span>
</div>

@if (Model != null && Model.Any())
{
    <div class="car-grid">
        @foreach (var item in Model)
        {
            var fuelClass = item.FuelType?.ToLower() switch
            {
                                        "petrol" => "fuel-petrol",
                                        "diesel" => "fuel-diesel",
                                        "electric" => "fuel-electric",
                                        "hybrid" => "fuel-hybrid",
                _ => "fuel-petrol"
            };
            var fuelIcon = item.FuelType?.ToLower() switch
            {
                                        "petrol" => "bi-droplet-fill",
                                        "diesel" => "bi-fuel-pump-fill",
                                        "electric" => "bi-lightning-fill",
                                        "hybrid" => "bi-recycle",
                _ => "bi-droplet-fill"
            };

            <div class="car-card">
                <div class="car-img-wrap">
                    @if (!string.IsNullOrEmpty(item.MainImageUrl))
                    {
                        <img src="@item.MainImageUrl" alt="@item.Model" class="car-img" />
                    }
                    else
                    {
                        <div class="car-img-placeholder">
                            <i class="bi bi-car-front" style="font-size:48px; color:#93c5fd;"></i>
                        </div>
                    }
                    <div class="car-img-overlay">
                        <span class="fuel-pill @fuelClass">
                            <i class="bi @fuelIcon"></i> @item.FuelType
                        </span>
                        <span class="trans-pill">
                            <i class="bi bi-gear-fill"></i> @item.Transmission
                        </span>
                    </div>
                </div>
                <div class="car-body">
                    <div class="car-header">
                        <div>
                            <div class="car-title">@item.BrandName @item.Model</div>
                            <span class="car-brand-badge"><i class="bi bi-bookmark-fill" style="font-size:9px;"></i> @item.BrandName</span>
                        </div>
                    </div>
                    <div class="car-specs">
                        <div class="spec-item">
                            <div class="spec-icon spec-icon-blue"><i class="bi bi-speedometer2"></i></div>
                            <span>@item.Mileage.ToString("N0") km</span>
                        </div>
                        <div class="spec-item">
                            <div class="spec-icon spec-icon-purple"><i class="bi bi-gear-fill"></i></div>
                            <span>@item.Transmission</span>
                        </div>
                        <div class="spec-item">
                            <div class="spec-icon spec-icon-green"><i class="bi bi-people-fill"></i></div>
                            <span>@item.Seats kişilik</span>
                        </div>
                        <div class="spec-item">
                            <div class="spec-icon spec-icon-amber"><i class="bi bi-briefcase-fill"></i></div>
                            <span>@item.LuggageCapacity bagaj</span>
                        </div>
                    </div>
                    <div class="car-actions">
                        <button class="btn-pricing" onclick="openPricing(@item.Id, '@item.BrandName @item.Model')" title="Fiyatlar">
                            <i class="bi bi-receipt" style="font-size:14px;"></i>
                        </button>
                        <a asp-area="Admin" asp-controller="CarFeature" asp-action="Index" asp-route-carId="@item.Id" class="btn-feature" title="Özellikler">
                            <i class="bi bi-gear-fill" style="font-size:14px;"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Car" asp-action="UpdateCar" asp-route-id="@item.Id" class="btn-edit" title="Düzenle">
                            <i class="bi bi-pencil-fill" style="font-size:14px;"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Car" asp-action="GetReviewByCarId" asp-route-id="@item.Id" class="btn-review" title="Değerlendirmeler">
                            <i class="bi bi-star-fill" style="font-size:14px;"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Car" asp-action="DeleteCar" asp-route-id="@item.Id" class="btn-delete" title="Sil">
                            <i class="bi bi-trash-fill" style="font-size:14px;"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-car-front" style="font-size:48px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz araç eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk aracı ekleyin.</div>
        <a asp-area="Admin" asp-controller="Car" asp-action="AddCar" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Araç Ekle
        </a>
    </div>
}

<!-- Pricing Modal -->
<div class="modal-overlay" id="pricing-modal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title-wrap">
                <div class="modal-icon">
                    <i class="bi bi-receipt" style="color:#a16207; font-size:16px;"></i>
                </div>
                <div class="modal-car-name" id="modal-car-name"></div>
            </div>
            <button class="modal-close" onclick="closePricing()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div id="modal-pricings"></div>
    </div>
</div>

<script>
    async function openPricing(id, carName) {
        document.getElementById('modal-car-name').textContent = carName;
        document.getElementById('modal-pricings').innerHTML = '<div class="pricing-loading"><i class="bi bi-arrow-repeat"></i> Yükleniyor...</div>';
        document.getElementById('pricing-modal').classList.add('active');

        try {
            const response = await fetch('https://localhost:7211/api/Car/ResultCarWithPricingForAdmin?id=' + id);
            const data = await response.json();
            var html = '';
            if (!data.pricings || data.pricings.length === 0) {
                html = '<div class="pricing-empty">Bu araç için fiyat bilgisi bulunamadı.</div>';
            } else {
                data.pricings.forEach(function (p) {
                    html += '<div class="pricing-row">'
                          + '<span class="pricing-row-name"><i class="bi bi-tag" style="font-size:11px; margin-right:5px;"></i>' + p.pricingName + '</span>'
                          + '<span class="pricing-row-amount">₺' + p.amount.toLocaleString('tr-TR') + '</span>'
                          + '</div>';
                });
            }
            document.getElementById('modal-pricings').innerHTML = html;
        } catch (e) {
            document.getElementById('modal-pricings').innerHTML = '<div class="pricing-empty">Fiyatlar yüklenirken hata oluştu.</div>';
        }
    }

    function closePricing() {
        document.getElementById('pricing-modal').classList.remove('active');
    }

    document.getElementById('pricing-modal').addEventListener('click', function (e) {
        if (e.target === this) closePricing();
    });
</script>