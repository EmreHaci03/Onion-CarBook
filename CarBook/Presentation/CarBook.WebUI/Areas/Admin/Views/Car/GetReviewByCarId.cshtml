@model List<GetReviewByCarIdDto>
@{
    ViewData["Title"] = "Değerlendirmeler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .rv-grid {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .rv-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px 22px;
        transition: box-shadow .2s, transform .2s;
    }

        .rv-card:hover {
            box-shadow: 0 8px 28px rgba(0,0,0,.07);
            transform: translateY(-1px);
        }

    .rv-head {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
    }

    .rv-avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
        color: #1d4ed8;
        font-size: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .rv-meta {
        flex: 1;
    }

    .rv-name {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .rv-sub {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .rv-date {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: #94a3b8;
    }

    .rv-comment {
        font-size: 13.5px;
        color: #475569;
        line-height: 1.75;
        background: #f8fafc;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 16px;
        border-left: 3px solid #fbb710;
    }

    .rv-ratings {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 14px;
    }

    .rv-rating-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 12px;
        text-align: center;
    }

    .rv-rating-val {
        font-size: 20px;
        font-weight: 700;
        color: #1d2127;
    }

    .rv-rating-stars {
        display: flex;
        justify-content: center;
        gap: 2px;
        margin: 3px 0;
    }

        .rv-rating-stars i {
            font-size: 10px;
            color: #fbb710;
        }

    .rv-rating-lbl {
        font-size: 10px;
        color: #94a3b8;
    }

    .rv-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 12px;
        border-top: 1px solid #f1f5f9;
    }

    .rv-car-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .rv-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .rv-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            color: #dc2626;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 60px 20px;
        text-align: center;
    }
</style>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <span style="font-size:13px; color:#64748b;">Toplam</span>
        <span style="background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; border-radius:20px; padding:3px 12px; font-size:11px; font-weight:600;">
            @(Model?.Count ?? 0) değerlendirme
        </span>
    </div>
    <a asp-area="Admin" asp-controller="Car" asp-action="Index"
       style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:9px; font-size:12px; font-weight:500; color:#374151; text-decoration:none;">
        <i class="bi bi-arrow-left"></i> Araçlara Dön
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="rv-grid">
        @foreach (var item in Model)
        {
            var avg = (item.CleanlinessRating + item.ComfortRating + item.PriceRating + item.DeliveryRating) / 4;

            <div class="rv-card">
                <div class="rv-head">
                    <div class="rv-avatar">@item.ReviewerName?.Substring(0, 1).ToUpper()</div>
                    <div class="rv-meta">
                        <div class="rv-name">@item.ReviewerName</div>
                        <div class="rv-sub">@item.CarModel</div>
                    </div>
                    <div class="rv-date">
                        <i class="bi bi-clock" style="font-size:10px;"></i>
                        @item.CreatedDate.ToString("dd MMM yyyy")
                    </div>
                </div>

                <div class="rv-comment">
                    <i class="bi bi-chat-quote" style="color:#fbb710; margin-right:6px;"></i>
                    @item.Comment
                </div>

                <div class="rv-ratings">
                    <div class="rv-rating-item">
                        <div class="rv-rating-val">@item.CleanlinessRating</div>
                        <div class="rv-rating-stars">
                            @for (int i = 0; i < item.CleanlinessRating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                        </div>
                        <div class="rv-rating-lbl">Temizlik</div>
                    </div>
                    <div class="rv-rating-item">
                        <div class="rv-rating-val">@item.ComfortRating</div>
                        <div class="rv-rating-stars">
                            @for (int i = 0; i < item.ComfortRating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                        </div>
                        <div class="rv-rating-lbl">Konfor</div>
                    </div>
                    <div class="rv-rating-item">
                        <div class="rv-rating-val">@item.PriceRating</div>
                        <div class="rv-rating-stars">
                            @for (int i = 0; i < item.PriceRating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                        </div>
                        <div class="rv-rating-lbl">Fiyat/Kalite</div>
                    </div>
                    <div class="rv-rating-item">
                        <div class="rv-rating-val">@item.DeliveryRating</div>
                        <div class="rv-rating-stars">
                            @for (int i = 0; i < item.DeliveryRating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                        </div>
                        <div class="rv-rating-lbl">Teslimat</div>
                    </div>
                </div>

                <div class="rv-footer">
                    <span class="rv-car-tag">
                        <i class="bi bi-car-front-fill"></i> @item.CarModel
                    </span>
                    <a asp-area="Admin" asp-controller="Car" asp-action="DeleteReview"
                       asp-route-id="@item.Id" class="rv-delete">
                        <i class="bi bi-trash-fill"></i> Sil
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <i class="bi bi-chat-square" style="font-size:48px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz değerlendirme yapılmamış</div>
        <div style="font-size:13px; color:#94a3b8;">Bu araç için henüz kullanıcı yorumu bulunmuyor.</div>
    </div>
}