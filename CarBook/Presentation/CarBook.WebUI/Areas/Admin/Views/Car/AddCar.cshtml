@model CreateCarDto
@{
    ViewData["Title"] = "Araç Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 20px;
        height: calc(100vh - 120px);
    }

    .left-panel {
        background: linear-gradient(145deg, #0f172a, #1e3a5f);
        border-radius: 16px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            background: rgba(59,130,246,.15);
            border-radius: 50%;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            background: rgba(99,102,241,.12);
            border-radius: 50%;
        }

    .left-top {
        position: relative;
        z-index: 1;
    }

    .left-icon {
        width: 52px;
        height: 52px;
        background: rgba(59,130,246,.2);
        border: 1px solid rgba(59,130,246,.3);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

        .left-icon i {
            font-size: 24px;
            color: #60a5fa;
        }

    .left-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 10px;
    }

    .left-desc {
        font-size: 13px;
        color: #94a3b8;
        line-height: 1.6;
    }

    .preview-box {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }

    .preview-img {
        width: 100%;
        height: 160px;
        object-fit: cover;
        background: rgba(255,255,255,.05);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .preview-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

    .preview-img-placeholder {
        font-size: 48px;
    }

    .preview-info {
        padding: 14px;
    }

    .preview-title {
        font-size: 15px;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 8px;
    }

    .preview-specs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
    }

    .preview-spec {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: #64748b;
    }

    .right-panel {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .right-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .right-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .right-subtitle {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .right-body {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
    }

    .field-group {
        margin-bottom: 16px;
    }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-label i {
            font-size: 13px;
            color: #94a3b8;
        }

    .field-hint {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 4px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 13px;
        color: #0f172a;
        font-family: 'Segoe UI', sans-serif;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        background: #fafafa;
        box-sizing: border-box;
    }

        .form-control:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            background: #fff;
        }

    select.form-control {
        cursor: pointer;
    }

    .text-danger {
        font-size: 11px;
        color: #dc2626;
        display: block;
        margin-top: 3px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .right-footer {
        padding: 16px 24px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
    }

    .footer-note {
        font-size: 11px;
        color: #94a3b8;
    }

    .form-actions {
        display: flex;
        gap: 8px;
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #374151;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #fff;
        cursor: pointer;
        transition: opacity .15s;
    }

        .btn-save:hover {
            opacity: .9;
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        margin-bottom: 16px;
        transition: color .15s;
    }

        .back-btn:hover {
            color: #374151;
        }
</style>

<a asp-area="Admin" asp-controller="Car" asp-action="Index" class="back-btn">
    <i class="bi bi-arrow-left"></i> Araç Listesine Dön
</a>

<div class="page-grid">
    <div class="left-panel">
        <div class="left-top">
            <div class="left-icon"><i class="bi bi-car-front-fill"></i></div>
            <div class="left-title">Yeni Araç Ekle</div>
            <div class="left-desc">Araç bilgilerini girerek yeni bir araç ekleyin.</div>
        </div>
        <div style="position:relative; z-index:1;">
            <div class="preview-box">
                <div class="preview-img" id="prev-img-wrap">
                    <span class="preview-img-placeholder">🚗</span>
                    <img id="prev-img" src="" alt="" />
                </div>
                <div class="preview-info">
                    <div class="preview-title" id="prev-title">Marka Model</div>
                    <div class="preview-specs">
                        <div class="preview-spec"><i class="bi bi-speedometer2" style="color:#60a5fa;"></i> <span id="prev-mileage">0 km</span></div>
                        <div class="preview-spec"><i class="bi bi-gear" style="color:#60a5fa;"></i> <span id="prev-trans">-</span></div>
                        <div class="preview-spec"><i class="bi bi-people" style="color:#60a5fa;"></i> <span id="prev-seats">0 kişi</span></div>
                        <div class="preview-spec"><i class="bi bi-droplet" style="color:#60a5fa;"></i> <span id="prev-fuel">-</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="right-panel">
        <div class="right-header">
            <div>
                <div class="right-title">Araç Bilgileri</div>
                <div class="right-subtitle">Tüm alanları eksiksiz doldurun</div>
            </div>
            <div style="width:36px; height:36px; background:#eff6ff; border-radius:8px; display:flex; align-items:center; justify-content:center;">
                <i class="bi bi-car-front" style="color:#3b82f6; font-size:16px;"></i>
            </div>
        </div>
        <div class="right-body">
            <form asp-action="AddCar" method="post" id="carForm">

                <div class="form-row">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-bookmark"></i> Marka</label>
                        <select name="BrandId" class="form-control" id="inp-brand">
                            <option value="">Marka Seçin</option>
                            @if (ViewBag.Brands != null)
                            {
                                @foreach (var brand in ViewBag.Brands)
                                {
                                    <option value="@brand.BrandId">@brand.BrandName</option>
                                }
                                }
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-car-front"></i> Model</label>
                        <input asp-for="Model" class="form-control" id="inp-model" placeholder="Örn: 3 Serisi, Corolla" />
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-gear"></i> Vites</label>
                        <select asp-for="Transmission" class="form-control" id="inp-trans">
                            <option value="">Seçin</option>
                            <option value="Manual">Manuel</option>
                            <option value="Automatic">Otomatik</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-droplet"></i> Yakıt Türü</label>
                        <select asp-for="FuelType" class="form-control" id="inp-fuel">
                            <option value="">Seçin</option>
                            <option value="Petrol">Benzin</option>
                            <option value="Diesel">Dizel</option>
                            <option value="Electric">Elektrik</option>
                            <option value="Hybrid">Hibrit</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-people"></i> Koltuk Sayısı</label>
                        <input asp-for="Seats" type="number" class="form-control" id="inp-seats" placeholder="5" min="1" max="9" />
                    </div>
                    <div class="field-group">
                        <label class="field-label"><i class="bi bi-briefcase"></i> Bagaj Kapasitesi</label>
                        <input asp-for="LuggageCapacity" type="number" class="form-control" placeholder="3" min="0" max="9" />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-speedometer2"></i> Kilometre</label>
                    <input asp-for="Mileage" type="number" class="form-control" id="inp-mileage" placeholder="15000" />
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-image"></i> Ana Görsel URL</label>
                    <input asp-for="MainImageUrl" class="form-control" id="inp-img" placeholder="https://images.unsplash.com/..." />
                    <div class="field-hint">Araç listesinde görünecek ana görsel URL'i.</div>
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-images"></i> Detay Görsel URL</label>
                    <input asp-for="DetailImageUrl" class="form-control" placeholder="https://images.unsplash.com/..." />
                    <div class="field-hint">Araç detay sayfasında görünecek görsel URL'i.</div>
                </div>

            </form>
        </div>
        <div class="right-footer">
            <div class="footer-note"><i class="bi bi-info-circle me-1"></i>Tüm alanlar zorunludur.</div>
            <div class="form-actions">
                <a asp-area="Admin" asp-controller="Car" asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> İptal
                </a>
                <button type="submit" form="carForm" class="btn-save">
                    <i class="bi bi-check-lg"></i> Aracı Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('inp-brand').addEventListener('change', updatePreview);
    document.getElementById('inp-model').addEventListener('input', updatePreview);
    document.getElementById('inp-mileage').addEventListener('input', function() {
        document.getElementById('prev-mileage').textContent = (parseInt(this.value) || 0).toLocaleString('tr-TR') + ' km';
    });
    document.getElementById('inp-trans').addEventListener('change', function() {
        var map = { 'Manual': 'Manuel', 'Automatic': 'Otomatik' };
        document.getElementById('prev-trans').textContent = map[this.value] || '-';
    });
    document.getElementById('inp-seats').addEventListener('input', function() {
        document.getElementById('prev-seats').textContent = (this.value || 0) + ' kişi';
    });
    document.getElementById('inp-fuel').addEventListener('change', function() {
        var map = { 'Petrol': 'Benzin', 'Diesel': 'Dizel', 'Electric': 'Elektrik', 'Hybrid': 'Hibrit' };
        document.getElementById('prev-fuel').textContent = map[this.value] || '-';
    });
    document.getElementById('inp-img').addEventListener('input', function() {
        var img = document.getElementById('prev-img');
        var placeholder = document.querySelector('.preview-img-placeholder');
        if (this.value) {
            img.src = this.value;
            img.style.display = 'block';
            placeholder.style.display = 'none';
        } else {
            img.style.display = 'none';
            placeholder.style.display = 'block';
        }
    });
    function updatePreview() {
        var brand = document.getElementById('inp-brand').options[document.getElementById('inp-brand').selectedIndex]?.text || '';
        var model = document.getElementById('inp-model').value || '';
        document.getElementById('prev-title').textContent = (brand === 'Marka Seçin' ? '' : brand) + ' ' + model || 'Marka Model';
    }
</script>
