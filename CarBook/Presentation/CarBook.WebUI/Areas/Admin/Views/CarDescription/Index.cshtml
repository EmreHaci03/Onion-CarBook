@{
    ViewData["Title"] = "Araç Açıklamaları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .desc-search-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px 16px;
    }

        .desc-search-bar i {
            color: #94a3b8;
            font-size: 16px;
        }

    .desc-search-input {
        border: none;
        outline: none;
        font-size: 13px;
        color: #0f172a;
        flex: 1;
        background: transparent;
    }

        .desc-search-input::placeholder {
            color: #cbd5e1;
        }

    .desc-id-input {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 7px 12px;
    }

        .desc-id-input input {
            border: none;
            outline: none;
            font-size: 13px;
            color: #0f172a;
            width: 80px;
            background: transparent;
        }

            .desc-id-input input::placeholder {
                color: #cbd5e1;
            }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: #3b82f6;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }

        .btn-search:hover {
            background: #2563eb;
        }

    .btn-reset {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-reset:hover {
            background: #e2e8f0;
        }

    .desc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 16px;
    }

    .desc-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s, transform .2s;
    }

        .desc-card:hover {
            box-shadow: 0 8px 30px rgba(0,0,0,.08);
            border-color: #bfdbfe;
            transform: translateY(-2px);
        }

    .desc-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .desc-car-name {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .desc-car-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #dbeafe;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #2563eb;
        flex-shrink: 0;
    }

    .desc-car-title {
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
    }

    .desc-car-sub {
        font-size: 10px;
        color: #94a3b8;
        margin-top: 1px;
    }

    .desc-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 10px;
        font-weight: 700;
    }

    .desc-card-body {
        padding: 14px 16px;
    }

    .desc-text {
        font-size: 12.5px;
        color: #475569;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .desc-card-footer {
        display: flex;
        gap: 8px;
        padding: 10px 16px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-edit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #1d4ed8;
            text-decoration: none;
        }

    .btn-delete {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 7px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        cursor: pointer;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 60px 20px;
        text-align: center;
    }

    .loading-box {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
        font-size: 14px;
    }

    .filter-chips {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 500;
    }

        .filter-chip button {
            background: none;
            border: none;
            cursor: pointer;
            color: #3b82f6;
            font-size: 12px;
            padding: 0;
            line-height: 1;
            margin-left: 2px;
        }

    /* Detail Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 16px;
        padding: 28px;
        width: 90%;
        max-width: 520px;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .modal-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .modal-title i {
            color: #3b82f6;
        }

    .modal-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        padding: 0;
        line-height: 1;
    }

        .modal-close:hover {
            color: #374151;
        }

    .modal-desc-text {
        font-size: 13.5px;
        color: #475569;
        line-height: 1.8;
        background: #f8fafc;
        border-radius: 10px;
        padding: 16px;
        border: 1px solid #e2e8f0;
    }

    /* Delete Confirm Modal */
    .del-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .del-modal-overlay.active {
            display: flex;
        }

    .del-modal-box {
        background: #fff;
        border-radius: 18px;
        padding: 0;
        width: 90%;
        max-width: 400px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,.22);
    }

    .del-modal-top {
        background: #fff5f5;
        padding: 28px 28px 22px;
        text-align: center;
        border-bottom: 1px solid #fee2e2;
    }

    .del-modal-icon {
        width: 56px;
        height: 56px;
        background: #fee2e2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
        font-size: 24px;
        color: #dc2626;
    }

    .del-modal-title {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .del-modal-car {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 12px;
        font-weight: 600;
        color: #dc2626;
        margin-top: 4px;
    }

    .del-modal-body {
        padding: 20px 28px 24px;
    }

    .del-modal-desc {
        font-size: 13px;
        color: #64748b;
        line-height: 1.6;
        background: #f8fafc;
        border-radius: 10px;
        padding: 12px 14px;
        border: 1px solid #e2e8f0;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .del-modal-actions {
        display: flex;
        gap: 10px;
    }

    .btn-del-cancel {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

        .btn-del-cancel:hover {
            background: #e2e8f0;
            color: #374151;
            text-decoration: none;
        }

    .btn-del-confirm {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px;
        background: #dc2626;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        cursor: pointer;
        transition: background .15s;
        text-decoration: none;
    }

        .btn-del-confirm:hover {
            background: #b91c1c;
            text-decoration: none;
        }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<!-- Toolbar -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge" id="count-badge">— açıklama</span>
    </div>
    <a asp-area="Admin" asp-controller="CarDescription" asp-action="AddDescription"
       style="display:inline-flex; align-items:center; gap:6px; padding:9px 18px; background:#3b82f6; color:#fff; border-radius:9px; text-decoration:none; font-size:12px; font-weight:600;">
        <i class="bi bi-plus-lg"></i> Açıklama Ekle
    </a>
</div>

<!-- Arama -->
<div class="desc-search-bar">
    <i class="bi bi-search"></i>
    <input type="text" class="desc-search-input" id="search-text" placeholder="Araç adı veya açıklama ile ara..." oninput="filterCards()" />
    <div class="desc-id-input">
        <i class="bi bi-hash" style="color:#94a3b8; font-size:13px;"></i>
        <input type="number" id="search-desc-id" placeholder="Description ID" min="1" />
    </div>
    <button class="btn-search" onclick="searchById()">
        <i class="bi bi-search" style="font-size:11px;"></i> ID ile Ara
    </button>
    <button class="btn-reset" onclick="resetSearch()">
        <i class="bi bi-x-lg" style="font-size:11px;"></i> Sıfırla
    </button>
</div>

<!-- Aktif Filtre -->
<div class="filter-chips" id="filter-chips" style="display:none;">
    <span style="font-size:12px; color:#64748b;">Filtre:</span>
    <div class="filter-chip">
        <i class="bi bi-funnel-fill" style="font-size:10px;"></i>
        <span id="active-filter-text"></span>
        <button onclick="resetSearch()"><i class="bi bi-x"></i></button>
    </div>
</div>

<!-- Liste -->
<div id="desc-container">
    <div class="loading-box">
        <i class="bi bi-arrow-repeat" style="font-size:28px; display:block; margin-bottom:10px; animation: spin 1s linear infinite;"></i>
        Açıklamalar yükleniyor...
    </div>
</div>

<!-- Detail Modal -->
<div class="modal-overlay" id="detail-modal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title"><i class="bi bi-card-text"></i><span id="modal-car-name"></span></div>
            <button class="modal-close" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-desc-text" id="modal-desc-text"></div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="del-modal-overlay" id="del-modal">
    <div class="del-modal-box">
        <div class="del-modal-top">
            <div class="del-modal-icon"><i class="bi bi-trash3-fill"></i></div>
            <div class="del-modal-title">Açıklamayı silmek istiyor musunuz?</div>
            <div class="del-modal-car"><i class="bi bi-car-front-fill" style="font-size:11px;"></i><span id="del-car-name"></span></div>
        </div>
        <div class="del-modal-body">
            <div class="del-modal-desc" id="del-desc-preview"></div>
            <div class="del-modal-actions">
                <button class="btn-del-cancel" onclick="closeDelModal()">
                    <i class="bi bi-x-lg" style="font-size:12px;"></i> Vazgeç
                </button>
                <a href="#" id="del-confirm-btn" class="btn-del-confirm">
                    <i class="bi bi-trash3-fill" style="font-size:12px;"></i> Evet, Sil
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    let allData = [];

    async function loadAll() {
        try {
            const res = await fetch('https://localhost:7211/api/CarDescription');
            allData = await res.json();
            document.getElementById('count-badge').textContent = allData.length + ' açıklama';
            renderCards(allData);
        } catch (e) {
            document.getElementById('desc-container').innerHTML = '<div class="empty-box"><i class="bi bi-exclamation-circle" style="font-size:36px; color:#fca5a5; display:block; margin-bottom:10px;"></i><div style="font-size:14px; color:#374151;">Veriler yüklenirken hata oluştu.</div></div>';
        }
    }

    async function searchById() {
        const id = document.getElementById('search-desc-id').value;
        if (!id) { resetSearch(); return; }
        document.getElementById('desc-container').innerHTML = '<div class="loading-box"><i class="bi bi-arrow-repeat" style="font-size:28px; display:block; margin-bottom:10px;"></i> Aranıyor...</div>';
        try {
            const res = await fetch('https://localhost:7211/api/CarDescription/GetById/' + id);
            if (!res.ok) throw new Error();
            const data = await res.json();
            document.getElementById('filter-chips').style.display = 'flex';
            document.getElementById('active-filter-text').textContent = 'Description ID: ' + id;
            document.getElementById('count-badge').textContent = '1 açıklama';
            document.getElementById('search-text').value = '';
            renderCards([data]);
        } catch (e) {
            document.getElementById('desc-container').innerHTML = '<div class="empty-box"><i class="bi bi-search" style="font-size:36px; color:#cbd5e1; display:block; margin-bottom:10px;"></i><div style="font-size:14px; color:#374151; margin-bottom:6px;">Sonuç bulunamadı</div><div style="font-size:12px; color:#94a3b8;">ID: ' + id + ' için açıklama yok</div></div>';
        }
    }

    function filterCards() {
        const q = document.getElementById('search-text').value.toLowerCase();
        if (!q) { renderCards(allData); document.getElementById('count-badge').textContent = allData.length + ' açıklama'; document.getElementById('filter-chips').style.display = 'none'; return; }
        const filtered = allData.filter(x => (x.carModel && x.carModel.toLowerCase().includes(q)) || (x.detailDescription && x.detailDescription.toLowerCase().includes(q)));
        document.getElementById('filter-chips').style.display = 'flex';
        document.getElementById('active-filter-text').textContent = '"' + q + '" araması';
        document.getElementById('count-badge').textContent = filtered.length + ' açıklama';
        renderCards(filtered);
    }

    function resetSearch() {
        document.getElementById('search-text').value = '';
        document.getElementById('search-desc-id').value = '';
        document.getElementById('filter-chips').style.display = 'none';
        document.getElementById('count-badge').textContent = allData.length + ' açıklama';
        renderCards(allData);
    }

    function renderCards(data) {
        if (!data || data.length === 0) {
            document.getElementById('desc-container').innerHTML = '<div class="empty-box"><i class="bi bi-file-earmark-text" style="font-size:42px; color:#cbd5e1; display:block; margin-bottom:14px;"></i><div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Açıklama bulunamadı</div><div style="font-size:13px; color:#94a3b8;">Farklı bir arama deneyin.</div></div>';
            return;
        }
        let html = '<div class="desc-grid">';
        data.forEach(function (item) {
            const desc = item.detailDescription || '—';
            const isLong = desc.length > 160;
            html += `
                <div class="desc-card">
                    <div class="desc-card-header">
                        <div class="desc-car-name">
                               ${item.mainImageUrl
                                   ? `<img src="${item.mainImageUrl}" style="width:30px;height:30px;border-radius:8px;object-fit:cover;flex-shrink:0;" />`
                                   : `<div class="desc-car-icon"><i class="bi bi-car-front-fill"></i></div>`
                               }
                            <div>
                                <div class="desc-car-title">${item.carModel || '—'}</div>
                                <div class="desc-car-sub">Araç ID: ${item.carId}</div>
                            </div>
                        </div>
                        <span class="desc-id-badge"><i class="bi bi-hash" style="font-size:9px;"></i>${item.id}</span>
                    </div>
                    <div class="desc-card-body">
                        <div class="desc-text">${desc}</div>
                        ${isLong ? `<button onclick="openModal('${item.carModel}', \`${desc.replace(/`/g, "'")}\`)" style="background:none; border:none; color:#3b82f6; font-size:11px; cursor:pointer; padding:6px 0 0; font-weight:500;"><i class="bi bi-arrows-expand" style="font-size:10px;"></i> Tamamını gör</button>` : ''}
                    </div>
                    <div class="desc-card-footer">
                        <a href="/Admin/CarDescription/UpdateDescription/${item.id}" class="btn-edit">
                            <i class="bi bi-pencil-fill" style="font-size:10px;"></i> Düzenle
                        </a>
                        <button class="btn-delete" onclick="openDelModal(${item.id}, '${item.carModel}', \`${desc.replace(/`/g, "'")}\`)">
                            <i class="bi bi-trash-fill" style="font-size:10px;"></i> Sil
                        </button>
                    </div>
                </div>`;
        });
        html += '</div>';
        document.getElementById('desc-container').innerHTML = html;
    }

    function openModal(carName, desc) {
        document.getElementById('modal-car-name').textContent = carName;
        document.getElementById('modal-desc-text').textContent = desc;
        document.getElementById('detail-modal').classList.add('active');
    }

    function closeModal() {
        document.getElementById('detail-modal').classList.remove('active');
    }

    function openDelModal(id, carName, desc) {
        document.getElementById('del-car-name').textContent = carName;
        document.getElementById('del-desc-preview').textContent = desc;
        document.getElementById('del-confirm-btn').href = '/Admin/CarDescription/DeleteDescription?id=' + id;
        document.getElementById('del-modal').classList.add('active');
    }

    function closeDelModal() {
        document.getElementById('del-modal').classList.remove('active');
    }

    document.getElementById('detail-modal').addEventListener('click', function (e) { if (e.target === this) closeModal(); });
    document.getElementById('del-modal').addEventListener('click', function (e) { if (e.target === this) closeDelModal(); });

    loadAll();
</script>
