@model List<ResultPricingDto>
@{
    ViewData["Title"] = "Fiyatlandırma Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddPricing", "Pricing", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .pricing-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s, transform .2s;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        padding: 0 20px 0 0;
    }

        .pricing-card:hover {
            box-shadow: 0 6px 24px rgba(0,0,0,.08);
            border-color: #cbd5e1;
            transform: translateY(-1px);
        }

    .pricing-icon-box {
        width: 110px;
        height: 86px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
    }

        .pricing-icon-box i {
            font-size: 30px;
            position: relative;
            z-index: 1;
        }

        /* Tipe göre renkler */
        .pricing-icon-box.type-hourly {
            background: linear-gradient(135deg, #fef9c3, #fde68a);
        }

            .pricing-icon-box.type-hourly i {
                color: #a16207;
            }

        .pricing-icon-box.type-daily {
            background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        }

            .pricing-icon-box.type-daily i {
                color: #1d4ed8;
            }

        .pricing-icon-box.type-monthly {
            background: linear-gradient(135deg, #ede9fe, #ddd6fe);
        }

            .pricing-icon-box.type-monthly i {
                color: #6d28d9;
            }

        .pricing-icon-box.type-default {
            background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        }

            .pricing-icon-box.type-default i {
                color: #475569;
            }

    .pricing-body {
        flex: 1;
        padding: 14px 18px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-width: 0;
    }

    .pricing-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 6px;
    }

    .badge-id {
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10px;
        font-weight: 600;
        font-family: monospace;
    }

    .badge-type {
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        .badge-type.type-hourly {
            background: #fef9c3;
            color: #a16207;
            border: 1px solid #fde68a;
        }

        .badge-type.type-daily {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .badge-type.type-monthly {
            background: #ede9fe;
            color: #6d28d9;
            border: 1px solid #ddd6fe;
        }

        .badge-type.type-default {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

    .pricing-name {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pricing-actions {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-shrink: 0;
    }

    .btn-pricing-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        background: #fefce8;
        border: 1px solid #fef08a;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #a16207;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-pricing-link:hover {
            background: #fef9c3;
            border-color: #fde047;
            color: #854d0e;
            text-decoration: none;
        }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge">@(Model?.Count ?? 0) fiyatlandırma</span>
    </div>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        var typeClass = "type-default";
        var typeIcon = "bi-cash-coin";
        var typeLabel = "Fiyatlandırma";

        var nameLower = (item.Name ?? "").ToLower();
        if (nameLower.Contains("saat"))
        {
            typeClass = "type-hourly";
            typeIcon = "bi-stopwatch";
            typeLabel = "Saatlik";
        }
        else if (nameLower.Contains("gün") || nameLower.Contains("gun"))
        {
            typeClass = "type-daily";
            typeIcon = "bi-calendar-day";
            typeLabel = "Günlük";
        }
        else if (nameLower.Contains("ay"))
        {
            typeClass = "type-monthly";
            typeIcon = "bi-calendar-month";
            typeLabel = "Aylık";
        }

        <div class="pricing-card">
            <div class="pricing-icon-box @typeClass">
                <i class="bi @typeIcon"></i>
            </div>
            <div class="pricing-body">
                <div class="pricing-meta">
                    <span class="badge-id">#@item.Id</span>
                    <span class="badge-type @typeClass">@typeLabel</span>
                </div>
                <div class="pricing-name">@item.Name</div>
            </div>
            <div class="pricing-actions">
                <a asp-area="Admin" asp-controller="Pricing" asp-action="UpdatePricing" asp-route-id="@item.Id" class="btn-edit">
                    <i class="bi bi-pencil" style="font-size:11px;"></i> Düzenle
                </a>
                <a asp-area="Admin" asp-controller="Pricing" asp-action="DeletePricing" asp-route-id="@item.Id" class="btn-delete">
                    <i class="bi bi-trash" style="font-size:11px;"></i> Sil
                </a>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-tags" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz fiyatlandırma eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk fiyatlandırmayı ekleyin.</div>
        <a asp-area="Admin" asp-controller="Pricing" asp-action="AddPricing" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Fiyatlandırma Ekle
        </a>
    </div>
}