@model List<ResultReservationDto>
@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-title-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 18px;
    }

    .stat-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

        .stat-icon.purple {
            background: #ede9fe;
        }

        .stat-icon.blue {
            background: #dbeafe;
        }

        .stat-icon.green {
            background: #dcfce7;
        }

        .stat-icon.amber {
            background: #fef3c7;
        }

    .stat-value {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: #64748b;
        margin-top: 3px;
    }

    .table-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        overflow: hidden;
    }

    .table-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .table-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .badge-count {
        background: #f1f5f9;
        color: #475569;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 20px;
    }

    .res-table {
        width: 100%;
        border-collapse: collapse;
    }

        .res-table thead tr {
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .res-table thead th {
            padding: 12px 20px;
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .6px;
            text-align: left;
            white-space: nowrap;
        }

        .res-table tbody tr {
            border-bottom: 1px solid #f8fafc;
            transition: background .12s;
        }

            .res-table tbody tr:last-child {
                border-bottom: none;
            }

            .res-table tbody tr:hover {
                background: #fafbff;
            }

        .res-table tbody td {
            padding: 14px 20px;
            vertical-align: middle;
        }

    .id-badge {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
    }

    .avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .customer-name {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
    }

    .customer-email {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 1px;
    }

    .contact-phone {
        font-size: 13px;
        color: #374151;
        font-weight: 500;
    }

    .car-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .date-block {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .date-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
    }

    .date-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

        .date-dot.pickup {
            background: #22c55e;
        }

        .date-dot.dropoff {
            background: #f59e0b;
        }

    .date-text {
        color: #374151;
        font-weight: 500;
    }

    .date-sub {
        font-size: 10px;
        color: #94a3b8;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .3px;
        min-width: 40px;
    }

    .loc-wrap {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .loc-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 6px;
    }

        .loc-chip.pickup {
            background: #eff6ff;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .loc-chip.dropoff {
            background: #faf5ff;
            color: #7c3aed;
            border: 1px solid #ddd6fe;
        }

    .age-wrap {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .age-item {
        font-size: 12px;
        color: #374151;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .age-label {
        font-size: 10px;
        color: #94a3b8;
        font-weight: 600;
        text-transform: uppercase;
    }

    .desc-text {
        font-size: 12px;
        color: #64748b;
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .empty-state {
        padding: 80px 20px;
        text-align: center;
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 32px;
    }

    .empty-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 6px;
    }

    .empty-sub {
        font-size: 13px;
        color: #94a3b8;
    }
</style>

<div class="page-header">
    <div class="page-title">
        <div class="page-title-icon">📋</div>
        Rezervasyon Listesi
    </div>
</div>

@if (Model != null)
{
    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-icon purple">📋</div>
            <div>
                <div class="stat-value">@Model.Count</div>
                <div class="stat-label">Toplam Rezervasyon</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">✅</div>
            <div>
                <div class="stat-value">@Model.Count(x => x.PickUpDate.HasValue && x.PickUpDate >= DateTime.Today)</div>
                <div class="stat-label">Yaklaşan</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon blue">🚗</div>
            <div>
                <div class="stat-value">@Model.Select(x => x.CarId).Distinct().Count()</div>
                <div class="stat-label">Farklı Araç</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon amber">📍</div>
            <div>
                <div class="stat-value">@Model.Select(x => x.PickUpLocationId).Distinct().Count()</div>
                <div class="stat-label">Alış Lokasyonu</div>
            </div>
        </div>
    </div>
}

<div class="table-card">
    <div class="table-card-header">
        <span class="table-card-title">Tüm Rezervasyonlar</span>
        @if (Model != null)
        {
            <span class="badge-count">@Model.Count kayıt</span>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="res-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Müşteri</th>
                    <th>Telefon</th>
                    <th>Araç</th>
                    <th>Tutar</th>
                    <th>Tarihler</th>
                    <th>Lokasyon</th>
                    <th>Yaş / Ehliyet</th>
                    <th>Açıklama</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var initials = ((item.ReservationName?.Length > 0 ? item.ReservationName[0].ToString() : "") +
                    (item.ReservationSurname?.Length > 0 ? item.ReservationSurname[0].ToString() : "")).ToUpper();
                    <tr>
                        <td>
                            <div class="id-badge">@item.ReservationId</div>
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="customer-name">@item.ReservationName @item.ReservationSurname</div>
                                    <div class="customer-email">@item.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="contact-phone">@item.PhoneNumber</span>
                        </td>
                        <td>
                            <span class="car-chip">
                                🚗 #@item.CarModel
                            </span>
                        </td>
                        <td>
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <span style="font-size:14px; font-weight:700; color:#2563eb;">@item.Amount.ToString("C")</span>
                                <span style="font-size:11px; color:#94a3b8;">@item.PricingType</span>
                            </div>
                        </td>
                        <td>
                            <div class="date-block">
                                <div class="date-item">
                                    <div class="date-dot pickup"></div>
                                    <span class="date-sub">Alış</span>
                                    <span class="date-text">
                                        @(item.PickUpDate.HasValue? item.PickUpDate.Value.ToString("dd.MM.yyyy") : "—")
                                    </span>
                                </div>
                                <div class="date-item">
                                    <div class="date-dot dropoff"></div>
                                    <span class="date-sub">Bırakış</span>
                                    <span class="date-text">
                                        @(item.DropOffDate.HasValue? item.DropOffDate.Value.ToString("dd.MM.yyyy") : "—")
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="loc-wrap">
                                <span class="loc-chip pickup">↑ #@(item.PickUpLocationName  ?? "")</span>
                                <span class="loc-chip dropoff">↓ #@(item.DropOffLocationName ?? "" )</span>
                            </div>
                        </td>
                        <td>
                            <div class="age-wrap">
                                <div class="age-item">
                                    <span class="age-label">Yaş</span>
                                    <span>@item.Age</span>
                                </div>
                                <div class="age-item">
                                    <span class="age-label">Ehliyet</span>
                                    <span>@item.DriverLicenseYear</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <span class="desc-text" title="@item.Description">@item.Description</span>
                            }
                            else
                            {
                                <span style="color:#cbd5e1; font-size:13px;">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <div class="empty-title">Rezervasyon bulunamadı</div>
            <div class="empty-sub">Henüz hiç rezervasyon oluşturulmamış.</div>
        </div>
    }
</div>