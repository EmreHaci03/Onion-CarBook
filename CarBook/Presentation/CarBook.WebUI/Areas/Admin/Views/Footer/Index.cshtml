@model List<ResultFooterAdressDto>
@{
    ViewData["Title"] = "Footer Yönetimi";
    ViewData["AddUrl"] = Url.Action("AddFooter", "Footer", new { area = "Admin" });
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .footer-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        transition: box-shadow .2s, border-color .2s;
        margin-bottom: 12px;
        display: flex;
    }

        .footer-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            border-color: #bfdbfe;
        }

    .footer-icon-wrap {
        width: 90px;
        flex-shrink: 0;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .footer-body {
        flex: 1;
        padding: 14px 18px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-width: 0;
    }

    .footer-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 6px;
    }

    .badge-address {
        font-size: 11px;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .badge-phone {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .badge-mail {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 10px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .footer-desc {
        font-size: 12px;
        color: #64748b;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .footer-actions {
        display: flex;
        gap: 8px;
        margin-top: 8px;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-edit:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 500;
        color: #dc2626;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
        }

    .empty-box {
        background: #fff;
        border: 2px dashed #e2e8f0;
        border-radius: 14px;
        padding: 60px 20px;
        text-align: center;
    }

    .count-badge {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div style="display:flex; align-items:center; gap:10px;">
        <div style="font-size:13px; color:#64748b;">Toplam</div>
        <span class="count-badge">@(Model?.Count ?? 0) kayıt</span>
    </div>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="footer-card">
            <div class="footer-icon-wrap">
                <i class="bi bi-layout-text-window-reverse" style="font-size:28px; color:#93c5fd;"></i>
            </div>
            <div class="footer-body">
                <div>
                    <div class="footer-meta">
                        <span class="badge-phone"><i class="bi bi-telephone-fill" style="font-size:9px;"></i> @item.Phone</span>
                        <span class="badge-mail"><i class="bi bi-envelope-fill" style="font-size:9px;"></i> @item.Mail</span>
                    </div>
                    <div class="badge-address" style="margin-bottom:4px;">
                        <i class="bi bi-geo-alt-fill" style="font-size:11px;"></i> @item.Address
                    </div>
                    <div class="footer-desc">@item.Description</div>
                </div>
                <div class="footer-actions">
                    <a asp-area="Admin" asp-controller="Footer" asp-action="UpdateFooter" asp-route-id="@item.Id" class="btn-edit">
                        <i class="bi bi-pencil" style="font-size:11px;"></i> Düzenle
                    </a>
                    <a asp-area="Admin" asp-controller="Footer" asp-action="DeleteFooter" asp-route-id="@item.Id" class="btn-delete">
                        <i class="bi bi-trash" style="font-size:11px;"></i> Sil
                    </a>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="empty-box">
        <i class="bi bi-layout-text-window-reverse" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:14px;"></i>
        <div style="font-size:15px; font-weight:600; color:#374151; margin-bottom:6px;">Henüz footer bilgisi eklenmemiş</div>
        <div style="font-size:13px; color:#94a3b8; margin-bottom:20px;">İlk footer bilgisini ekleyin.</div>
        <a asp-area="Admin" asp-controller="Footer" asp-action="AddFooter" style="display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; border-radius:9px; text-decoration:none; font-size:13px; font-weight:500;">
            <i class="bi bi-plus-lg"></i> Ekle
        </a>
    </div>
}