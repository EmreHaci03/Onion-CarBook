@model UpdateFooterAdressDto
@{
    ViewData["Title"] = "Footer Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 20px;
        height: calc(100vh - 120px);
    }

    .left-panel {
        background: linear-gradient(145deg, #0f1f3d, #1e3a5f);
        border-radius: 16px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        position: relative;
    }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            background: rgba(59,130,246,.12);
            border-radius: 50%;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            background: rgba(99,102,241,.1);
            border-radius: 50%;
        }

    .left-top {
        position: relative;
        z-index: 1;
    }

    .left-icon {
        width: 52px;
        height: 52px;
        background: rgba(59,130,246,.2);
        border: 1px solid rgba(59,130,246,.3);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

        .left-icon i {
            font-size: 24px;
            color: #60a5fa;
        }

    .left-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .left-desc {
        font-size: 13px;
        color: #94a3b8;
        line-height: 1.6;
    }

    .tips {
        position: relative;
        z-index: 1;
    }

    .tip-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 14px;
    }

    .tip-dot {
        width: 22px;
        height: 22px;
        background: rgba(59,130,246,.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

        .tip-dot i {
            font-size: 11px;
            color: #60a5fa;
        }

    .tip-text {
        font-size: 12px;
        color: #94a3b8;
        line-height: 1.5;
    }

        .tip-text strong {
            color: #cbd5e1;
            font-weight: 600;
        }

    .preview-box {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 12px;
        padding: 16px;
        position: relative;
        z-index: 1;
    }

    .preview-label {
        font-size: 10px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .preview-desc {
        font-size: 12px;
        color: #cbd5e1;
        line-height: 1.5;
        margin-bottom: 10px;
    }

    .preview-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        color: #94a3b8;
        margin-bottom: 6px;
    }

        .preview-row i {
            color: #60a5fa;
            font-size: 12px;
            width: 16px;
        }

    .right-panel {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .right-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .right-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }

    .right-subtitle {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .right-body {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
    }

    .field-group {
        margin-bottom: 18px;
    }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .field-label i {
            font-size: 13px;
            color: #94a3b8;
        }

    .field-hint {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 4px;
    }

    .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        font-size: 13px;
        color: #0f172a;
        font-family: 'Segoe UI', sans-serif;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        background: #fafafa;
    }

        .form-control:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            background: #fff;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 85px;
    }

    .text-danger {
        font-size: 11px;
        color: #dc2626;
        display: block;
        margin-top: 3px;
    }

    .right-footer {
        padding: 16px 24px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
    }

    .footer-note {
        font-size: 11px;
        color: #94a3b8;
    }

    .form-actions {
        display: flex;
        gap: 8px;
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        text-decoration: none;
        transition: all .15s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #374151;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #fff;
        cursor: pointer;
        transition: opacity .15s;
    }

        .btn-save:hover {
            opacity: .9;
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        margin-bottom: 16px;
        transition: color .15s;
    }

        .back-btn:hover {
            color: #374151;
        }

    .edit-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        color: #1d4ed8;
        font-weight: 500;
    }
</style>

<a asp-area="Admin" asp-controller="Footer" asp-action="Index" class="back-btn">
    <i class="bi bi-arrow-left"></i> Footer Listesine Dön
</a>

<div class="page-grid">
    <div class="left-panel">
        <div class="left-top">
            <div class="left-icon"><i class="bi bi-pencil-square"></i></div>
            <div class="left-title">Footer Düzenleme</div>
            <div class="left-desc">İletişim ve adres bilgilerini güncelleyebilirsiniz. Değişiklikleriniz kaydedildikten sonra sitenin alt kısmında anında görünür.</div>
        </div>
        <div>
            <div class="tips">
                <div class="tip-item">
                    <div class="tip-dot"><i class="bi bi-pencil"></i></div>
                    <div class="tip-text"><strong>Açıklamayı</strong> ziyaretçilere şirketinizi tanıtacak şekilde kısa tutun.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot"><i class="bi bi-eye"></i></div>
                    <div class="tip-text"><strong>Önizleme</strong> ile değişikliklerinizi kaydetmeden görebilirsiniz.</div>
                </div>
                <div class="tip-item">
                    <div class="tip-dot"><i class="bi bi-shield-check"></i></div>
                    <div class="tip-text"><strong>Kaydet</strong> butonuna basana kadar değişiklikler uygulanmaz.</div>
                </div>
            </div>
            <div class="preview-box">
                <div class="preview-label">Canlı Önizleme</div>
                <div class="preview-desc" id="prev-desc">@Model?.Description</div>
                <div class="preview-row"><i class="bi bi-geo-alt-fill"></i> <span id="prev-address">@Model?.Address</span></div>
                <div class="preview-row"><i class="bi bi-telephone-fill"></i> <span id="prev-phone">@Model?.Phone</span></div>
                <div class="preview-row"><i class="bi bi-envelope-fill"></i> <span id="prev-mail">@Model?.Mail</span></div>
            </div>
        </div>
    </div>

    <div class="right-panel">
        <div class="right-header">
            <div>
                <div class="right-title">Footer Bilgilerini Güncelle</div>
                <div class="right-subtitle">Değiştirmek istediğiniz alanları düzenleyin</div>
            </div>
            <span class="edit-badge"><i class="bi bi-pencil-fill"></i> Düzenleme Modu</span>
        </div>
        <div class="right-body">
            <form asp-action="UpdateFooter" method="post" id="updateForm">
                <input asp-for="Id" type="hidden" />

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-card-text"></i> Açıklama</label>
                    <textarea asp-for="Description" class="form-control" id="inp-desc" placeholder="Footer açıklama metni"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-geo-alt"></i> Adres</label>
                    <input asp-for="Address" class="form-control" id="inp-address" placeholder="Örn: Atatürk Cad. No:1, İstanbul" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-telephone"></i> Telefon</label>
                    <input asp-for="Phone" class="form-control" id="inp-phone" placeholder="Örn: +90 555 123 45 67" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                    <div class="field-hint">Footer alanında iletişim numarası olarak gösterilir.</div>
                </div>

                <div class="field-group">
                    <label class="field-label"><i class="bi bi-envelope"></i> E-posta</label>
                    <input asp-for="Mail" class="form-control" id="inp-mail" placeholder="Örn: info@carbook.com" />
                    <span asp-validation-for="Mail" class="text-danger"></span>
                </div>
            </form>
        </div>
        <div class="right-footer">
            <div class="footer-note"><i class="bi bi-clock-history me-1"></i>Son değişiklikler anında yayınlanır.</div>
            <div class="form-actions">
                <a asp-area="Admin" asp-controller="Footer" asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> İptal
                </a>
                <button type="submit" form="updateForm" class="btn-save">
                    <i class="bi bi-check-lg"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('inp-desc').addEventListener('input', function() {
        document.getElementById('prev-desc').textContent = this.value || 'Açıklama metni burada görünecek...';
    });
    document.getElementById('inp-address').addEventListener('input', function() {
        document.getElementById('prev-address').textContent = this.value || 'Adres burada görünecek...';
    });
    document.getElementById('inp-phone').addEventListener('input', function() {
        document.getElementById('prev-phone').textContent = this.value || 'Telefon burada görünecek...';
    });
    document.getElementById('inp-mail').addEventListener('input', function() {
        document.getElementById('prev-mail').textContent = this.value || 'E-posta burada görünecek...';
    });
</script>